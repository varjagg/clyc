(defun tva-cache-unbuilt? ()
  "[Cyc] Return whether the TVA cache registry has not been built."
  (let ((result nil))
    (let ((*relevant-mt-function* #'relevant-mt-is-any-mt)
          (*mt* #$InferencePSC))
      (setf result (or (not (map-p *tva-cache-registry*))
                       (and (map-empty-p *tva-cache-registry*)
                            (> (num-predicate-extent-index #$cacheTransitiveClosureForArgs)
                               0)))))
    result))

