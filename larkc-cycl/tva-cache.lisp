(defparameter *use-tva-cache?* t
  "[Cyc] Whether to use the TVA cache.")

(defglobal *tva-cache-registry* (make-hash-table :test #'eql)
  "[Cyc] DICTIONARY-P mapping binary predicates to their TVA-CACHE-P objects.")

(defparameter *tva-cache-assume-supports-are-valid?* nil)

(deflexical *tva-cache-max-instances-to-cache-caching-state* nil)

(defconstant *cfasl-opcode-tva-cache* 96)

;; Setup phase

(toplevel
  (note-memoized-function 'tva-cache-valid-support?)
  (register-kb-function 'add-tva-cache-value)
  (register-kb-function 'remove-tva-cache-value)
  (register-kb-function 'add-tva-cache-key)
  (register-kb-function 'remove-tva-cache-key)
  (note-globally-cached-function 'tva-cache-max-instances-to-cache)
  (register-cfasl-input-function *cfasl-opcode-tva-cache* 'cfasl-input-tva-cache)
  (defmethod cfasl-output-object ((object tva-cache) stream)
    (cfasl-output-object-tva-cache-method object stream))
  (define-obsolete-register 'dump-tva-cache-to-stream '(dump-swappable-tva-cache-to-stream)))
