(defun reconnect-tva-cache-registry (directory common-symbols)
  "[Cyc] Helper method for system KB initializations code."
  (let ((data-file (get-tva-cache-contents-data-file directory))
        (index-file (get-tva-cache-contents-index-file directory)))
    (reconnect-tva-cache-registry-to-file-vector-files data-file index-file common-symbols)))

(defun reconnect-tva-cache-registry-to-file-vector-files (data-file index-file
                                                          &optional (common-symbols
                                                                     (cfasl-current-common-symbols)))
  "[Cyc] Walks the TVA cache registry and reconnects all of the TVA caches registered."
  (declare (ignore common-symbols))
  (let ((valid-files (and (file-exists? data-file) (file-exists? index-file))))
    (if valid-files
        (let ((fvector (new-file-vector data-file index-file))
              (iterator (new-map-iterator *tva-cache-registry*)))
          (declare (ignore fvector))
          (loop
            (multiple-value-bind (entry valid) (iteration-next iterator)
              (unless valid (return))
              (destructuring-bind (key tva-caches) entry
                (declare (ignore key))
                (dolist (v-tva-cache tva-caches)
                  (declare (ignore v-tva-cache))
                  (missing-larkc 3823))))))
        (warn "Reconnecting to legacy unit files w/out TVA cache contents in ~A and ~A."
              data-file index-file))
    valid-files))

