;; Reconstructed from Internal Constants:
;; $list0 = ((CACHE BIN-PRED) &BODY BODY), $sym1 = PRED-CACHES (unintern gensym),
;; $sym2 = DO-DICTIONARY, $list3 = ((TVA-CACHE-REGISTRY)), $sym4 = CDOLIST
(defmacro do-tva-caches ((cache bin-pred) &body body)
  "[Cyc] Iterate over all TVA caches in the registry, binding BIN-PRED to each
predicate and CACHE to each cache for that predicate."
  (with-temp-vars (pred-caches)
    `(do-dictionary (,bin-pred ,pred-caches (tva-cache-registry))
       (dolist (,cache ,pred-caches)
         ,@body))))

;; Reconstructed from Internal Constants:
;; $list5 = ((KEY RAW-SUPPORTED-VALUES SUPPORTED-SUBKEYS CACHE) &BODY BODY),
;; $sym6 = ENTRY (unintern gensym), $sym7 = DO-MAP, $sym8 = TVA-CACHE-MAP,
;; $sym9 = CDESTRUCTURING-BIND, $list18 = (KEY #:ENTRY),
;; $list19 = (RAW-SUPPORTED-VALUES . SUPPORTED-SUBKEYS)
(defmacro do-tva-cache ((key raw-supported-values supported-subkeys cache) &body body)
  "[Cyc] Iterate over the entries of a TVA CACHE's map, destructuring each entry
into KEY, RAW-SUPPORTED-VALUES, and SUPPORTED-SUBKEYS."
  (with-temp-vars (entry)
    `(maphash (lambda (,key ,entry)
                (destructuring-bind (,raw-supported-values . ,supported-subkeys) ,entry
                  ,@body))
              (tva-cache-map ,cache))))

