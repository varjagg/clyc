(defun add-tva-cache-value (argument assertion)
  "[Cyc] We've just added a new key->value support to the KB."
  (declare (ignore argument))
  (destructuring-bind (bin-pred arg1 arg2)
      (formula-terms (gaf-hl-formula assertion))
    (declare (ignore arg1 arg2))
    (multiple-value-bind (caches inverse-caches)
        (tva-caches-implied-by-predicate bin-pred)
      (let ((mt-var (with-inference-mt-relevance-validate (assertion-mt assertion))))
        (let ((*mt* (update-inference-mt-relevance-mt mt-var))
              (*relevant-mt-function* (update-inference-mt-relevance-function mt-var))
              (*relevant-mts* (update-inference-mt-relevance-mt-list mt-var)))
          (dolist (v-cache caches)
            (let ((pcase-var (tva-cache-index-argnum v-cache)))
              (cond
                ((eql pcase-var 1) (missing-larkc 3889))
                ((eql pcase-var 2) (missing-larkc 3890)))))
          (dolist (v-cache inverse-caches)
            (let ((pcase-var (tva-cache-index-argnum v-cache)))
              (cond
                ((eql pcase-var 2) (missing-larkc 3891))
                ((eql pcase-var 1) (missing-larkc 3892)))))))))
  nil)

(defun remove-tva-cache-value (argument assertion)
  "[Cyc] We're about to remove a key->value support from the KB."
  (declare (ignore argument))
  (destructuring-bind (bin-pred arg1 arg2)
      (formula-terms (gaf-hl-formula assertion))
    (declare (ignore arg1 arg2))
    (multiple-value-bind (caches inverse-caches)
        (tva-caches-implied-by-predicate bin-pred)
      (let ((mt-var (with-inference-mt-relevance-validate (assertion-mt assertion))))
        (let ((*mt* (update-inference-mt-relevance-mt mt-var))
              (*relevant-mt-function* (update-inference-mt-relevance-function mt-var))
              (*relevant-mts* (update-inference-mt-relevance-mt-list mt-var)))
          (dolist (v-cache caches)
            (let ((pcase-var (tva-cache-index-argnum v-cache)))
              (cond
                ((eql pcase-var 1) (missing-larkc 3872))
                ((eql pcase-var 2) (missing-larkc 3873)))))))
      ;; Note: inverse-caches loop is OUTSIDE with-inference-mt-relevance (matches Java)
      (dolist (v-cache inverse-caches)
        (let ((pcase-var (tva-cache-index-argnum v-cache)))
          (cond
            ((eql pcase-var 2) (missing-larkc 3874))
            ((eql pcase-var 1) (missing-larkc 3875)))))))
  nil)

