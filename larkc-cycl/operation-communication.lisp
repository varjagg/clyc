;; commented declareFunction, but body present in Java -- ported for reference
(defun halt-cyc-image (&optional (reason "done"))
  "[Cyc] Gracefully halt a running Cyc image"
  (warn "Halting Cyc image : ~A" reason)
  (halt-agenda)
  (when (kb-loaded)
    (save-transcript-ops)
    (mark-local-transcript "QUIT")
    (save-recent-experience)
    (save-recent-asked-queries))
  (sb-ext:exit :code 0)
  nil)

