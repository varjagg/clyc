(defun set-to-not-receiving ()
  (set-receiving-remote-operations? nil)
  nil)

(defun transmitting-change? (new-mode)
  "[Cyc] Is the change in communication-mode going to change the way processed
operations are handled?"
  (if (equal (get-transmit-state new-mode)
             (get-transmit-state (communication-mode)))
      nil
      t))

(defun receiving-change? (new-mode)
  "[Cyc] Is the change in communication-mode going to change the receive part of
the mode?"
  (if (equal (get-receive-state new-mode)
             (get-receive-state (communication-mode)))
      nil
      t))

;; (defun set-to-receive-only () ...) -- 0/0, commented declareFunction, no body

(defun set-to-deaf ()
  (when (transmitting-change? :deaf)
    (set-to-storing))
  (when (receiving-change? :deaf)
    (set-to-not-receiving))
  (set-communication-mode-internal :deaf)
  :deaf)

