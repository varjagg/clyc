(defun remote-operation-to-run? ()
  "[Cyc] Return T iff there are remote operations available to run."
  (and (receiving-remote-operations?)
       ;; missing-larkc 22949: likely checks if the remote operation queue is non-empty
       ;; (e.g. remote-queue-empty returns T when empty, negated here)
       (not (missing-larkc 22949))))

