(defun the-cyclist ()
  *the-cyclist*)

(defun set-the-cyclist (&optional name)
  (let ((fort (map-cyclist-name-to-cyclist-term name)))
    (setf *the-cyclist* fort)
    *the-cyclist*))

(defun map-cyclist-name-to-cyclist-term (name)
  (let ((cyclist-term (if (stringp name)
                          (fi-find-int name)
                          (if (valid-fort? name)
                              name
                              nil))))
    (if (and cyclist-term
             (cyclist? cyclist-term))
        cyclist-term
        #$Guest)))

