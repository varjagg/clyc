(defun transmitting? ()
  (if (or (equal (communication-mode) :transmit-only)
          (equal (communication-mode) :transmit-and-receive))
      t
      nil))

(defun storing? ()
  (if (or (equal (communication-mode) :deaf)
          (equal (communication-mode) :receive-only))
      t
      nil))

;; (defun not-recording? () ...) -- 0/0, commented declareFunction, no body
;; (defun receiving? () ...) -- 0/0, commented declareFunction, no body

(defun get-transmit-state (&optional (mode (communication-mode)))
  "[Cyc] @return TRANSMIT-STATE-P"
  (let ((state nil))
    (cond
      ((or (eq mode :transmit-and-receive)
           (eq mode :transmit-only))
       (setf state "transmit"))
      ((or (eq mode :deaf)
           (eq mode :receive-only))
       (setf state "store"))
      ((or (eq mode :dead)
           (eq mode :dead-receive))
       (setf state "none"))
      (t
       (setf state nil)))
    state))

(defun get-receive-state (&optional (mode (communication-mode)))
  "[Cyc] @return RECEIVE-STATE-P"
  (let ((state nil))
    (cond
      ((or (eq mode :transmit-and-receive)
           (eq mode :receive-only)
           (eq mode :dead-receive))
       (setf state "yes"))
      ((or (eq mode :deaf)
           (eq mode :transmit-only)
           (eq mode :dead))
       (setf state "no"))
      (t
       (setf state nil)))
    state))

