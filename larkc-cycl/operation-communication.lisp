(defun kb-version-string ()
  "[Cyc] Return the current KB version, i.e. both KB number and number of master
transcript operations performed."
  (if (> (read-master-transcript-op-number) 0)
      (format nil "~a.~a" (kb-loaded) (read-master-transcript-op-number))
      (format nil "~a" (kb-loaded))))

