(defun save-transcript-ops ()
  (when *hl-transcripts-enabled?*
    ;; missing-larkc 12960: likely save-hl-transcript-ops or similar,
    ;; handles saving HL transcript operations when HL transcripts are enabled
    (missing-larkc 12960))
  (when (not (transcript-queue-empty))
    (bt:with-lock-held (*save-transcript-ops-lock*)
      (save-transcript-ops-internal))
    (return-from save-transcript-ops t))
  nil)

(defun save-transcript-ops-internal (&optional transcript-known-to-exist)
  (declare (ignore transcript-known-to-exist))
  (let ((local-transcript (local-transcript)))
    (with-open-file (stream local-transcript :direction :output
                                             :if-exists :append
                                             :if-does-not-exist :create)
      (unless (streamp stream)
        (error "Unable to open ~S" local-transcript))
      (let ((*print-level* nil)
            (*print-length* nil))
        (loop until (transcript-queue-empty)
              for op = (transcript-queue-dequeue)
              do (when (and (not (dont-record-operations-locally))
                            (storing?))
                   (format stream "~s~%" op)
                   (local-operation-storage-queue-enqueue op)
                   (inc-total-local-operations-recorded))
                 (when (and (allow-transmitting)
                            (transmitting?))
                   ;; missing-larkc 22952: likely transmit-queue-enqueue or similar,
                   ;; queues the operation for transmission to the master transcript
                   (missing-larkc 22952)
                   ;; missing-larkc 12946: likely inc-total-local-operations-transmitted,
                   ;; increments the count of transmitted local operations
                   (missing-larkc 12946))))))
  nil)

