(defun communication-mode ()
  "[Cyc] Accessor for *communication-mode*."
  *communication-mode*)

(defun set-communication-mode-internal (mode)
  (setf *communication-mode* mode)
  *communication-mode*)

(defun set-communication-mode (&optional (keyword :receive-only))
  (check-type keyword symbol)
  (when (null (cyc-image-id))
    (set-cyc-image-id))
  (when (not (eq (communication-mode) keyword))
    (when (null (master-transcript))
      (set-master-transcript))
    (when (and *init-file-loaded?*
               (local-transcript))
      (save-transcript-ops))
    (cond
      ((eq keyword :transmit-and-receive)
       ;; missing-larkc 12972: likely set-to-transmit-and-receive, which would
       ;; configure the image for both sending and receiving transcript operations
       (missing-larkc 12972))
      ((eq keyword :transmit-only)
       ;; missing-larkc 12973: likely set-to-transmit-only, which would
       ;; configure the image for sending transcript operations only
       (missing-larkc 12973))
      ((eq keyword :deaf)
       (set-to-deaf))
      ((eq keyword :dead)
       ;; missing-larkc 12968: likely set-to-dead, which would configure
       ;; the image for neither recording nor receiving operations
       (missing-larkc 12968))
      ((eq keyword :dead-receive)
       ;; missing-larkc 12969: likely set-to-dead-receive, which would configure
       ;; the image for receiving but not recording operations
       (missing-larkc 12969))
      (t
       ;; missing-larkc 12970: likely handles the default/unknown communication mode case
       (missing-larkc 12970))))
  (communication-mode))

