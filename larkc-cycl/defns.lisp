(defun defns-cache-unbuilt? ()
  "[Cyc] Return T if the defns cache has not yet been populated."
  (not (and (hash-table-p *has-suf-defn-cache*)
            (not (hash-table-empty-p *has-suf-defn-cache*))
            (hash-table-p *iff-defns*)
            (not (hash-table-empty-p *iff-defns*))
            (hash-table-p *suf-defns*)
            (not (hash-table-empty-p *suf-defns*))
            (hash-table-p *nec-defns*)
            (not (hash-table-empty-p *nec-defns*))
            (hash-table-p *has-quoted-suf-defn-cache*)
            (not (hash-table-empty-p *has-quoted-suf-defn-cache*))
            (hash-table-p *quoted-iff-defns*)
            (not (hash-table-empty-p *quoted-iff-defns*))
            (hash-table-p *quoted-suf-defns*)
            (hash-table-p *quoted-nec-defns*)
            (hash-table-p *suf-defn-cache*)
            (not (hash-table-empty-p *suf-defn-cache*))
            (hash-table-p *suf-quoted-defn-cache*)
            (not (hash-table-empty-p *suf-quoted-defn-cache*))
            (hash-table-p *suf-function-cache*)
            (not (hash-table-empty-p *suf-function-cache*))
            (hash-table-p *suf-quoted-function-cache*)
            (not (hash-table-empty-p *suf-quoted-function-cache*)))))

(defun clear-defns-cache ()
  "[Cyc] Clear all defns and suf-defn caches."
  (clear-defns)
  (clear-suf-defns)
  (clear-suf-quoted-defns)
  (clear-suf-functions)
  (clear-suf-quoted-functions)
  nil)

