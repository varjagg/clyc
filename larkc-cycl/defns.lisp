;;; ======================================================================
;;; Genl-for-suf-defns handlers
;;; ======================================================================

(defun handle-added-genl-for-suf-defns-int (spec genl quoted?)
  "[Cyc] Handle an added genls link from SPEC to GENL, propagating suf-defn counts."
  (let ((spec-suf-count (suf-defn-count spec quoted?)))
    (when (and (integerp spec-suf-count) (> spec-suf-count 0))
      (with-all-mts
        ;; Walk all genls of GENL, incrementing suf-defn counts.
        ;; This is an inline expansion of do-all-genls on #$genls module forward.
        ;; Since sbhl modules are unported, we use all-genls instead.
        (dolist (genl-col (all-genls genl))
          ;; missing-larkc 10594 likely calls inc-suf-defn-count for genl-col
          (missing-larkc 10594)))))
  nil)

(define-defn-metered new-handle-added-genl-for-suf-defns (spec genl)
  (handle-added-genl-for-suf-defns-int spec genl nil))

(define-defn-metered new-handle-added-genl-for-suf-quoted-defns (spec genl)
  (handle-added-genl-for-suf-defns-int spec genl t))

(defun handle-removed-genl-for-suf-defns-int (spec genl quoted?)
  "[Cyc] Handle a removed genls link from SPEC to GENL, updating suf-defn counts."
  (with-all-mts
    (unless (genl? spec genl)
      (let ((spec-suf-count (suf-defn-count spec quoted?)))
        (when (and (integerp spec-suf-count) (> spec-suf-count 0))
          ;; Walk all genls of GENL, decrementing suf-defn counts.
          ;; Since sbhl modules are unported, we use all-genls instead.
          (dolist (genl-col (all-genls genl))
            ;; missing-larkc 10590 likely calls dec-suf-defn-count for genl-col
            (missing-larkc 10590))))))
  nil)

(define-defn-metered new-handle-removed-genl-for-suf-defns (spec genl)
  (handle-removed-genl-for-suf-defns-int spec genl nil))

(define-defn-metered new-handle-removed-genl-for-suf-quoted-defns (spec genl)
  (handle-removed-genl-for-suf-defns-int spec genl t))

;;; ======================================================================
;;; Cache management
;;; ======================================================================

(defun clear-defns ()
  "[Cyc] Clear all defn caches."
  (unless *use-new-defns-functions?*
    (return-from clear-defns nil))
  (when *has-suf-defn-cache*
    (clrhash *has-suf-defn-cache*))
  (when *iff-defns*
    (clrhash *iff-defns*))
  (when *suf-defns*
    (clrhash *suf-defns*))
  (when *nec-defns*
    (clrhash *nec-defns*))
  (when *has-quoted-suf-defn-cache*
    (clrhash *has-quoted-suf-defn-cache*))
  (when *quoted-iff-defns*
    (clrhash *quoted-iff-defns*))
  (when *quoted-suf-defns*
    (clrhash *quoted-suf-defns*))
  (when *quoted-nec-defns*
    (clrhash *quoted-nec-defns*))
  nil)

