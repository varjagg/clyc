(defun suf-defn-count (col quoted?)
  "[Cyc] Return the suf-defn count for COL."
  (unless (or *has-suf-defn-cache* *has-quoted-suf-defn-cache*)
    ;; missing-larkc 10597 likely initializes the defns cache
    (missing-larkc 10597))
  (if quoted?
      (gethash col *has-quoted-suf-defn-cache*)
      (gethash col *has-suf-defn-cache*)))

(defun has-suf-defn-somewhere? (col quoted?)
  "[Cyc] Return T if COL has a suf-defn somewhere."
  (and (suf-defn-count col quoted?) t))

;; (defun set-suf-defn-count (col count quoted?) ...) -- commented declareFunction (3 0)
;; (defun rem-suf-defn-count (col quoted?) ...) -- commented declareFunction (2 0)

(defun iff-defn (col quoted?)
  "[Cyc] Return the iff-defn for COL."
  (unless (or *iff-defns* *quoted-iff-defns*)
    ;; missing-larkc 10600 likely initializes the defns cache
    (missing-larkc 10600))
  (if quoted?
      (gethash col *quoted-iff-defns*)
      (gethash col *iff-defns*)))

;; (defun rem-iff-defn (col quoted?) ...) -- commented declareFunction (2 0)

(defun suf-defns (col quoted?)
  "[Cyc] Return the suf-defns for COL."
  (unless (or *suf-defns* *quoted-suf-defns*)
    ;; missing-larkc 10602 likely initializes the defns cache
    (missing-larkc 10602))
  (if quoted?
      (gethash col *quoted-suf-defns*)
      (gethash col *suf-defns*)))

;; (defun rem-suf-defn (col defn quoted?) ...) -- commented declareFunction (3 0)
;; (defun new-suf-defn? (col &optional quoted?) ...) -- commented declareFunction (2 1)

(defun nec-defns (col quoted?)
  "[Cyc] Return the nec-defns for COL."
  (unless (or *nec-defns* *quoted-nec-defns*)
    ;; missing-larkc 10604 likely initializes the defns cache
    (missing-larkc 10604))
  (if quoted?
      (gethash col *quoted-nec-defns*)
      (gethash col *nec-defns*)))

;; (defun rem-nec-defn (col defn quoted?) ...) -- commented declareFunction (3 0)

(defun has-some-defn? (col quoted?)
  "[Cyc] Return T if COL has some defn (iff, suf, or nec)."
  (or (iff-defn col quoted?)
      (suf-defns col quoted?)
      (nec-defns col quoted?)
      nil))

;;; ======================================================================
;;; Metering infrastructure
;;; ======================================================================

(define-defn-metered new-defns-admit? (col term &optional (mt *mt*))
  (defns-admit?-int col term mt nil))

(defun defns-admit?-int (col term mt quoted?)
  "[Cyc] Return T if all defns for COL admit TERM in MT."
  (when (reifiable-nat? col)
    ;; missing-larkc 10336 likely calls nart-substitute to get the reified form
    (setf col (missing-larkc 10336)))
  (when (permitting-denotational-terms-admitted-by-defn-via-isa?)
    (if quoted?
        (when (quoted-isa? term col mt)
          (return-from defns-admit?-int t))
        (when (isa? term col mt)
          (return-from defns-admit?-int t))))
  (unless (or (fort-p col)
              (has-suf-defn-somewhere? col quoted?))
    (return-from defns-admit?-int nil))
  (let ((admitted? nil))
    (let ((*defn-fn-history* (possibly-make-defn-fn-history-table))
          (*quoted-defn-fn-history* (possibly-make-quoted-defn-fn-history-table))
          (*defn-col-history* (possibly-make-defn-col-history-table))
          (*quoted-defn-col-history* (possibly-make-quoted-defn-col-history-table)))
      (unwind-protect
           (let ((status (initial-check-defn-admit-status col term mt quoted?)))
             (case status
               (:admitted (setf admitted? t))
               (:rejected (setf admitted? nil))
               (otherwise
                (if (defns-walk-admit? col term mt quoted?)
                    (setf admitted? t)
                    (when (and (not quoted?)
                               (fast-quote-term-p term))
                      ;; missing-larkc 31111 likely calls cycl-denotation-term
                      ;; to get the denoted term from the quoted expression
                      (let ((denoted-term (missing-larkc 31111)))
                        (when (and denoted-term
                                   (quoted-defns-admit? col denoted-term mt))
                          (setf admitted? t))))))))
        (clear-defn-space)))
    admitted?))

(define-defn-metered new-defns-reject? (col term &optional (mt *mt*))
  (defns-reject?-int col term mt nil))

(defun defns-reject?-int (col term mt quoted?)
  "[Cyc] Return T if defns for COL reject TERM in MT."
  (when (reifiable-nat? col)
    ;; missing-larkc 10337 likely calls nart-substitute to get the reified form
    (setf col (missing-larkc 10337)))
  (when (permitting-denotational-terms-admitted-by-defn-via-isa?)
    (if quoted?
        (when (quoted-isa? term col mt)
          (return-from defns-reject?-int nil))
        (when (isa? term col mt)
          (return-from defns-reject?-int nil))))
  (unless (fort-p col)
    (return-from defns-reject?-int nil))
  (let ((rejected? nil))
    (let ((*defn-fn-history* (possibly-make-defn-fn-history-table))
          (*quoted-defn-fn-history* (possibly-make-quoted-defn-fn-history-table))
          (*defn-col-history* (possibly-make-defn-col-history-table))
          (*quoted-defn-col-history* (possibly-make-quoted-defn-col-history-table)))
      (unwind-protect
           (let ((status (initial-check-defn-admit-status col term mt quoted?)))
             (case status
               (:admitted (setf rejected? nil))
               (:rejected (setf rejected? t))
               (otherwise
                (if (nec-defn-rejects? col term mt quoted?)
                    (setf rejected? t)
                    (when (and (not quoted?)
                               (fast-quote-term-p term))
                      ;; missing-larkc 31112 likely calls cycl-denotation-term
                      (let ((denoted-term (missing-larkc 31112)))
                        (when (and denoted-term
                                   ;; missing-larkc 5429 likely calls
                                   ;; quoted-defns-reject? for the denoted term
                                   (missing-larkc 5429))
                          (setf rejected? t))))))))
        (clear-defn-space)))
    rejected?))

(define-defn-metered new-quoted-defns-admit? (col term &optional (mt *mt*))
  (defns-admit?-int col term mt t))

;; new-quoted-defns-reject?-metered and new-quoted-defns-reject? are commented out
;; in Java (//declareFunction (2 1)); only reset-new-quoted-defns-reject?-meters is active.
(define-defn-metered new-quoted-defns-reject? (col term &optional (mt *mt*))
  (missing-larkc "new-quoted-defns-reject?-metered and new-quoted-defns-reject? do not exist in Java; only the reset function is active."))

;;; ======================================================================
;;; Defn checking logic
;;; ======================================================================

(defun initial-check-defn-admit-status (col term mt quoted?)
  "[Cyc] If the defnIff of the COL explicitly admits or rejects TERM, return result.
Otherwise, return :rejected if a necessaryDefn of genls of COL rejects the TERM.
Will delegate to the correct defns checks for quoted/non-quoted using QUOTED?"
  (let ((admit-status (defining-defns-admits? col term mt quoted?))
        (done? nil))
    (case admit-status
      (:admitted)
      (:rejected)
      (otherwise
       (when *at-apply-necessary-defns?*
         (let ((*defn-collection* col))
           (unless done?
             ;; Walk genls of COL checking nec-defn-rejects? for each.
             ;; This is an inline expansion of (do-all-genls (genl col :direction :forward) ...)
             ;; which uses the sbhl module for #$genls.
             ;; Since sbhl modules are unported, we use genls:all-genls instead.
             (dolist (genl (all-genls col mt))
               (when done? (return))
               (when (not (eq genl col))
                 (when (nec-defn-rejects? genl term mt quoted? t)
                   (setf done? t)
                   (setf admit-status :rejected)))))))))
    admit-status))

(defun defns-walk-admit? (col term mt quoted?)
  "[Cyc] Walk genls of COL, checking defn admission."
  (let ((result nil))
    (let ((*defn-term* term)
          (*org-collection* col)
          (*failing-suf-defns* nil))
      (if quoted?
          (setf result (sbhl-simply-gather-first-among-all-backward-true-nodes-with-prune
                        (get-sbhl-module #$genls) col #'col-quoted-defn-admits? mt))
          (setf result (sbhl-simply-gather-first-among-all-backward-true-nodes-with-prune
                        (get-sbhl-module #$genls) col #'col-defn-admits? mt)))
      (when (and (not result)
                 *noting-at-violations?*
                 *include-suf-defn-violations?*
                 *failing-suf-defns*)
        ;; missing-larkc 7223 likely checks some condition about suf-defn violations
        (when (missing-larkc 7223)
          ;; missing-larkc 11308 likely records suf-defn violation
          (missing-larkc 11308))))
    result))

;; (defun sufficient-defn-violations (col term mt quoted? violations) ...) -- commented declareFunction (5 0)
;; (defun sufficient-defn-violation (col term mt quoted? violation assertion) ...) -- commented declareFunction (6 0)

(defun col-defn-admits? (col)
  "[Cyc] Does COL's defn admit the current *defn-term*?"
  (col-defn-admits?-int col *defn-term* *mt* nil))

;; (defun col-quoted-defn-admits? (col) ...) -- commented declareFunction (1 0)

(defun col-defn-admits?-int (col term mt quoted?)
  "[Cyc] Implementation of col-defn-admits? with explicit args."
  (unless (has-suf-defn-somewhere? col quoted?)
    (return-from col-defn-admits?-int (list nil t)))
  (unless (has-some-defn? col quoted?)
    (return-from col-defn-admits?-int (list nil nil)))
  (let ((result nil)
        (done? nil)
        (status (if (eq *org-collection* col)
                    t
                    (defining-defns-admits? col term mt quoted?))))
    (case status
      (:admitted (setf result t done? t))
      (:rejected (setf result nil done? t))
      (otherwise
       (when (nec-defn-permits? col term mt quoted? nil)
         (when (suf-defn-admits? col term mt quoted?)
           (setf result t done? t)))
       (unless done?
         (setf result nil done? t))))
    (list result done?)))

(defun defining-defns-admits? (col term mt quoted?)
  "[Cyc] Check the iff-defn of COL for whether it admits TERM in MT."
  (let ((iff-defn (iff-defn col quoted?))
        (admit-status nil))
    (when (null iff-defn)
      (return-from defining-defns-admits? nil))
    (possibly-in-mt (mt)
      (when (and (valid-assertion iff-defn)
                 (relevant-mt? (assertion-mt iff-defn)))
        (let ((defn (cycl-subl-symbol-symbol (gaf-arg2 iff-defn))))
          (let ((*defn-collection* col))
            (when (viable-defn? defn col)
              (if (if quoted?
                      (quoted-defn-admits? defn term col mt)
                      (defn-admits? defn term col mt))
                  (setf admit-status :admitted)
                  (progn
                    (setf admit-status :rejected)
                    (when *noting-at-violations?*
                      ;; missing-larkc 11309 likely records iff-defn violation
                      (missing-larkc 11309)))))))))
    admit-status))

;; (defun defining-defn-violations (col term mt quoted? assertion) ...) -- commented declareFunction (5 0)
;; (defun defining-defn-violation (col term mt quoted? violation assertion) ...) -- commented declareFunction (6 0)

(defun suf-defn-admits? (col term mt quoted?)
  "[Cyc] Check whether any sufficient defn of COL admits TERM in MT."
  (let ((suf-defns (suf-defns col quoted?))
        (admitted? nil)
        (done? nil))
    (when (null suf-defns)
      (return-from suf-defn-admits? nil))
    (possibly-in-mt (mt)
      (unless done?
        (dolist (suf-defn suf-defns)
          (when done? (return))
          (when (and (valid-assertion suf-defn)
                     (relevant-mt? (assertion-mt suf-defn)))
            (let ((defn (cycl-subl-symbol-symbol (gaf-arg2 suf-defn))))
              (let ((*defn-collection* col))
                (when (viable-defn? defn col)
                  (if (if quoted?
                          ;; missing-larkc 5365 likely calls quiet-quoted-defn-admits?
                          (missing-larkc 5365)
                          (quiet-defn-admits? defn term col mt))
                      (progn
                        (setf admitted? t)
                        (setf done? t))
                      (progn
                        (setf admitted? nil)
                        (setf done? nil)
                        (when *noting-at-violations?*
                          (pushnew defn *failing-suf-defns*)))))))))))
    admitted?))

(defun nec-defn-permits? (col term mt quoted? &optional (consider-iff-as-nec? nil))
  "[Cyc] Return T if the necessary defns of COL permit TERM in MT."
  (not (nec-defn-rejects? col term mt quoted? consider-iff-as-nec?)))

(define-defn-metered nec-defn-rejects? (col term mt quoted? &optional (consider-iff-as-nec? nil))
  "[Cyc] Do the necessary defns of COL reject TERM in MT?"
  (let ((nec-defns (nec-defns col quoted?))
        (rejected? nil)
        (done? nil))
    (when (null nec-defns)
      (when consider-iff-as-nec?
        (setf nec-defns (list (iff-defn col quoted?))))
      (when (null nec-defns)
        (return-from nec-defn-rejects?-metered nil)))
    (possibly-in-mt (mt)
      (unless done?
        (dolist (nec-defn nec-defns)
          (when done? (return))
          (when (and (valid-assertion nec-defn)
                     (relevant-mt? (assertion-mt nec-defn)))
            (let ((defn (cycl-subl-symbol-symbol (gaf-arg2 nec-defn))))
              (let ((*defn-collection* col))
                (when (viable-defn? defn col)
                  (if (if quoted?
                          (quoted-defn-admits? defn term col mt)
                          (defn-admits? defn term col mt))
                      (progn
                        (setf rejected? nil)
                        (setf done? nil))
                      (progn
                        (setf rejected? t)
                        (setf done? t)
                        (when *noting-at-violations?*
                          ;; missing-larkc 11310 likely records nec-defn violation
                          (missing-larkc 11310)))))))))))
    rejected?))

