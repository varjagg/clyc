(defun load-defns-cache-from-stream (stream)
  "[Cyc] Load defns cache from a CFASL stream."
  (setf *has-suf-defn-cache* (cfasl-input stream))
  (setf *iff-defns* (cfasl-input stream))
  (setf *suf-defns* (cfasl-input stream))
  (setf *nec-defns* (cfasl-input stream))
  (setf *has-quoted-suf-defn-cache* (cfasl-input stream))
  (setf *quoted-iff-defns* (cfasl-input stream))
  (setf *quoted-suf-defns* (cfasl-input stream))
  (setf *quoted-nec-defns* (cfasl-input stream))
  (setf *suf-defn-cache* (cfasl-input stream))
  (setf *suf-quoted-defn-cache* (cfasl-input stream))
  (setf *suf-function-cache* (cfasl-input stream))
  (setf *suf-quoted-function-cache* (cfasl-input stream))
  ;; Three dummy reads for forward compatibility
  (cfasl-input stream)
  (cfasl-input stream)
  (cfasl-input stream)
  nil)

