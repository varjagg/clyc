;;; ======================================================================
;;; Variables
;;; ======================================================================

(defvar *has-suf-defn-cache* nil)
(defvar *has-quoted-suf-defn-cache* nil)
(defvar *iff-defns* nil)
(defvar *quoted-iff-defns* nil)
(defvar *suf-defns* nil)
(defvar *quoted-suf-defns* nil)
(defvar *nec-defns* nil)
(defvar *quoted-nec-defns* nil)
(defvar *defn-term* nil)
(defvar *org-collection* nil)
(defvar *failing-suf-defns* nil)

;; Metering state vars for the first 5 metered functions are generated by
;; define-defn-metered macro calls below (in the Metering infrastructure section).

(deflexical *min-defn-admits-map*
    (list (list #'stringp #$CharacterString)
          (list #'positive-integer-p #$PositiveInteger)
          (list #'non-negative-integer-p #$NonNegativeInteger)
          (list #'integerp #$Integer)
          (list #'floatp #$RealNumber)
          (list (constantly t) #$Thing)))

(deflexical *min-quoted-defn-admits-map*
    (list (list #'stringp #$SubLString)
          (list #'integerp #$SubLInteger)
          (list #'floatp #$SubLRealNumber)
          (list #'symbolp #$SubLSymbol)
          (list #'constant-p #$CycLConstant)
          (list #'nart-p #$CycLNonAtomicReifiedTerm)
          (list #'assertion-p #$CycLAssertion)
          (list (constantly t) #$CycLExpression)))

;; Metering state vars for the handle-*-genl-for-suf-*-defns functions are
;; generated by define-defn-metered macro calls below (Genl-for-suf-defns section).

