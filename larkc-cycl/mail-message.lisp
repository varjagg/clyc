(in-package :clyc)


;; MESSAGE structure

(defstruct (message (:conc-name "MSG-")
                    (:print-function print-message))
  from
  to
  cc
  bcc
  subject
  additional-headers
  host
  port
  parts)

(defconstant *dtp-message* 'message)


;; MESSAGE-PART structure

(defstruct (message-part (:conc-name "MSG-PART-")
                         (:print-function print-message-part))
  content-type
  content-type-parameters
  disposition
  content-disposition-parameters
  encoding
  data
  data-type)

(defconstant *dtp-message-part* 'message-part)


;; Functions (declare section ordering)

;; MESSAGE struct accessors/mutators are generated by defstruct above.

(defun message-print-function-trampoline (object stream)
  "[Cyc] Print function trampoline for MESSAGE."
  (print-message object stream 0))

(defun message-p (object)
  "[Cyc] Return T if OBJECT is a MESSAGE structure."
  (typep object 'message))

;; MSG-FROM, MSG-TO, MSG-CC, MSG-BCC, MSG-SUBJECT, MSG-ADDITIONAL-HEADERS,
;; MSG-HOST, MSG-PORT, MSG-PARTS — generated by defstruct
;; _CSETF-MSG-FROM etc. — (setf msg-from) generated by defstruct

(defun make-message (&optional arglist)
  "[Cyc] Create a new MESSAGE, optionally with keyword arguments."
  (declare (ignore arglist))
  (make-message))

(defun print-message (object stream depth)
  "[Cyc] Print a MESSAGE."
  (declare (ignore depth))
  (format stream "<MESSAGE>"))

(defun new-message (&optional from to subject host port cc)
  "[Cyc] Create a new MESSAGE with the given fields."
  (declare (type (or null string) from to subject cc)
           (type (or null string) host)
           (type (or null integer) port))
  (let ((msg (make-message)))
    (when from (setf (msg-from msg) from))
    (when to (setf (msg-to msg) (list to)))
    (when subject (setf (msg-subject msg) subject))
    (setf (msg-host msg) (or host "localhost"))
    (when port (setf (msg-port msg) port))
    (when cc (setf (msg-cc msg) (list cc)))
    msg))

(defun message-set-from (message from)
  "[Cyc] Set the FROM field of MESSAGE."
  (setf (msg-from message) from))

(defun message-from (message)
  "[Cyc] Return the FROM field of MESSAGE."
  (msg-from message))

(defun message-add-to (message to)
  "[Cyc] Add TO to the recipients of MESSAGE."
  (setf (msg-to message) (append (msg-to message) (list to))))

(defun message-to (message)
  "[Cyc] Return the TO list of MESSAGE."
  (msg-to message))

(defun message-add-cc (message cc)
  "[Cyc] Add CC to the carbon-copy list of MESSAGE."
  (setf (msg-cc message) (append (msg-cc message) (list cc))))

(defun message-cc (message)
  "[Cyc] Return the CC list of MESSAGE."
  (msg-cc message))

(defun message-add-bcc (message bcc)
  "[Cyc] Add BCC to the blind-carbon-copy list of MESSAGE."
  (setf (msg-bcc message) (append (msg-bcc message) (list bcc))))

(defun message-bcc (message)
  "[Cyc] Return the BCC list of MESSAGE."
  (msg-bcc message))

(defun message-set-subject (message subject)
  "[Cyc] Set the SUBJECT of MESSAGE."
  (setf (msg-subject message) subject))

(defun message-subject (message)
  "[Cyc] Return the SUBJECT of MESSAGE."
  (msg-subject message))

(defun message-add-header (message header)
  "[Cyc] Add HEADER to the additional headers of MESSAGE."
  (setf (msg-additional-headers message)
        (append (msg-additional-headers message) (list header))))

(defun message-additional-headers (message)
  "[Cyc] Return the additional headers of MESSAGE."
  (msg-additional-headers message))

(defun message-set-host (message host)
  "[Cyc] Set the HOST of MESSAGE."
  (setf (msg-host message) host))

(defun message-host (message)
  "[Cyc] Return the HOST of MESSAGE."
  (msg-host message))

(defun message-set-port (message port)
  "[Cyc] Set the PORT of MESSAGE."
  (setf (msg-port message) port))

(defun message-port (message)
  "[Cyc] Return the PORT of MESSAGE."
  (msg-port message))

(defun message-add-part (message part)
  "[Cyc] Add PART to the parts of MESSAGE."
  (setf (msg-parts message) (append (msg-parts message) (list part))))

(defun message-parts (message)
  "[Cyc] Return the parts of MESSAGE."
  (msg-parts message))

