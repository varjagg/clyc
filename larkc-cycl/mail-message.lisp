;; MESSAGE-PART struct accessors/mutators are generated by defstruct above.

(defun message-part-print-function-trampoline (object stream)
  "[Cyc] Print function trampoline for MESSAGE-PART."
  (print-message-part object stream 0))

(defun message-part-p (object)
  "[Cyc] Return T if OBJECT is a MESSAGE-PART structure."
  (typep object 'message-part))

;; MSG-PART-CONTENT-TYPE, MSG-PART-CONTENT-TYPE-PARAMETERS, MSG-PART-DISPOSITION,
;; MSG-PART-CONTENT-DISPOSITION-PARAMETERS, MSG-PART-ENCODING, MSG-PART-DATA,
;; MSG-PART-DATA-TYPE — generated by defstruct
;; _CSETF-MSG-PART-* — (setf msg-part-*) generated by defstruct

(defun make-message-part (&optional arglist)
  "[Cyc] Create a new MESSAGE-PART, optionally with keyword arguments."
  (declare (ignore arglist))
  (make-message-part))

(defun print-message-part (object stream depth)
  "[Cyc] Print a MESSAGE-PART."
  (declare (ignore depth))
  (format stream "<MESSAGE-PART (~A)" (msg-part-content-type object))
  (format stream ">"))

(defun new-inline-message-part (data &optional content-type encoding)
  "[Cyc] Create a new inline MESSAGE-PART."
  (new-message-part (or content-type "text/plain")
                    "inline"
                    (or encoding "7bit")
                    data
                    :string))

(defun new-message-attachment (filename &optional content-type encoding data-type)
  "[Cyc] Create a new attachment MESSAGE-PART."
  (new-message-part (or content-type "text/plain")
                    "attachment"
                    (or encoding "7bit")
                    filename
                    (or data-type :file)))

(defun valid-message-part-data-type-p (data-type)
  "[Cyc] Return T if DATA-TYPE is a valid message part data type."
  (member data-type '(:string :file)))

(defun valid-message-part-encoding-p (encoding)
  "[Cyc] Return T if ENCODING is a valid message part encoding."
  (member encoding '("7bit" "8bit" "binary") :test #'string=))

(defun new-message-part (content-type disposition encoding data data-type)
  "[Cyc] Create a new MESSAGE-PART with the given fields."
  (let ((part (make-message-part)))
    (setf (msg-part-content-type part) content-type)
    (setf (msg-part-disposition part) disposition)
    (setf (msg-part-encoding part) encoding)
    (setf (msg-part-data part) data)
    (setf (msg-part-data-type part) data-type)
    part))

(defun message-part-content-type (part)
  "[Cyc] Return the content type of PART."
  (msg-part-content-type part))

(defun message-part-set-content-type (part content-type)
  "[Cyc] Set the content type of PART."
  (setf (msg-part-content-type part) content-type))

(defun message-part-content-disposition-parameters (part)
  "[Cyc] Return the content disposition parameters of PART."
  (msg-part-content-disposition-parameters part))

(defun message-part-set-attachment-name (part name)
  "[Cyc] Set the attachment name of PART."
  (message-part-set-content-disposition-parameter part :filename name))

(defun message-part-disposition (part)
  "[Cyc] Return the disposition of PART."
  (msg-part-disposition part))

(defun message-part-encoding (part)
  "[Cyc] Return the encoding of PART."
  (msg-part-encoding part))

(defun message-part-data (part)
  "[Cyc] Return the data of PART."
  (msg-part-data part))

(defun message-part-data-type (part)
  "[Cyc] Return the data type of PART."
  (msg-part-data-type part))

(defun sxhash-message-part-method (object)
  "[Cyc] Sxhash method for MESSAGE-PART."
  (missing-larkc 29966))

;; (defun sxhash-message-part (part) ...) -- active declareFunction, no body

(defun message-part-set-content-disposition-parameter (part key value)
  "[Cyc] Set a content disposition parameter on PART."
  (setf (msg-part-content-disposition-parameters part)
        (cons (cons key value)
              (remove key (msg-part-content-disposition-parameters part) :key #'car))))

