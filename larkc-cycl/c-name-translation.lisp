(deflexical *c-backend-function-name-table* :uninitialized)

(defun initialize-c-backend-function-name-table ()
  (let* ((data (nconc (copy-list *c-backend-defined-function-name-data*)
                      (copy-list *c-backend-undefined-function-name-data*)
                      (copy-list *c-backend-undefined-arity-function-name-data*)
                      (copy-list *c-backend-undefined-boolean-function-name-data*)))
         (table (make-hash-table :test 'eq :size (length data))))
    (dolist (item data)
      (destructuring-bind (symbol c-backend-name &optional arglist) item
        (declare (ignore arglist))
        (setf (gethash symbol table) c-backend-name)))
    (setf *c-backend-function-name-table* table)
    table))

(deflexical *c-backend-function-arglist-table* :uninitialized)

(defun initialize-c-backend-function-arglist-table ()
  (let ((table (make-hash-table :test 'eq :size 500)))
    (dolist (item *c-backend-defined-function-name-data*)
      (destructuring-bind (symbol c-backend-name) item
        (declare (ignore c-backend-name))
        (when (function-symbol-p symbol)
          (let ((arglist (function-symbol-arglist symbol)))
            (setf (gethash symbol table) arglist)))))
    (let ((data (nconc (copy-list *c-backend-undefined-function-name-data*)
                       (copy-list *c-backend-undefined-arity-function-name-data*)
                       (copy-list *c-backend-undefined-boolean-function-name-data*))))
      (dolist (item data)
        (destructuring-bind (symbol c-backend-name &optional arglist) item
          (declare (ignore c-backend-name))
          (setf (gethash symbol table) arglist))))
    (setf *c-backend-function-arglist-table* table)
    table))

