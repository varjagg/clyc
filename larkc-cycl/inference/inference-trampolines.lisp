(defun inference-collection? (object &optional mt)
  (or (and (fort-p object)
           (collection? object))
      (and (possibly-naut-p object)
           (isa? object #$Collection mt))))

(defun inference-predicate-p (object)
  (and (fort-p object)
       (predicate? object)))

(defun inference-commutative-relation? (relation)
  (commutative-relation-p relation))

(defun inference-symmetric-predicate? (predicate)
  (symmetric-binary-predicate-p predicate))

(defun inference-commutative-predicate-p (predicate)
