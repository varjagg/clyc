(defun problem-backchain-required? (problem)
  "[Cyc] Return T iff PROBLEM is backchain required"
  (declare (type problem-p problem))
  (let ((query (problem-query problem)))
    (dolist (contextualized-dnf-clause query)
      (unless (inference-some-backchain-required-asent-in-clause?
               contextualized-dnf-clause)
        (return-from problem-backchain-required? nil)))
    t))

(defun inference-some-backchain-required-asent-in-clause? (contextualized-dnf-clause)
  (dolist (contextualized-asent (neg-lits contextualized-dnf-clause))
    (when (inference-backchain-required-contextualized-asent? contextualized-asent)
      (return-from inference-some-backchain-required-asent-in-clause? t)))
  (dolist (contextualized-asent (pos-lits contextualized-dnf-clause))
    (when (inference-backchain-required-contextualized-asent? contextualized-asent)
      (return-from inference-some-backchain-required-asent-in-clause? t)))
  nil)

(defun inference-backchain-required-contextualized-asent? (contextualized-asent)
  (let ((asent (contextualized-asent-asent contextualized-asent))
        (mt (contextualized-asent-mt contextualized-asent)))
    (inference-backchain-required-asent? asent mt)))

(defun inference-backchain-required-asent? (asent mt)
  (setf mt (backchain-control-mt mt))
  (let ((pred (atomic-sentence-predicate asent)))
    (when (fort-p pred)
      (when (inference-predicate-backchain-required? pred mt)
        (return-from inference-backchain-required-asent? t))
      (when (member pred (list #$isa #$genls) :test #'eq)
        (let ((col (atomic-sentence-arg2 asent)))
          (when (fort-p col)
            (when (inference-collection-backchain-required? col mt)
              (return-from inference-backchain-required-asent? t))
            (when (and (eq pred #$isa)
                       (inference-collection-isa-backchain-required? col mt))
              (return-from inference-backchain-required-asent? t))
            (when (and (eq pred #$genls)
                       (inference-collection-genls-backchain-required? col mt))
              (return-from inference-backchain-required-asent? t)))))))
  nil)

(defun-memoized inference-predicate-backchain-required? (predicate mt) (:test eq)
  (backchain-required? predicate (backchain-control-mt mt)))

(defun-memoized inference-backchain-forbidden? (predicate mt) (:test eq)
  (backchain-forbidden? predicate (backchain-control-mt mt)))

