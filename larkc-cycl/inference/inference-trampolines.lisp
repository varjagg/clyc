(defun backchain-control-mt (mt)
  "[Cyc] Assuming that we are doing inference MT, return the mt in which to look for
assertions that control the behaviour of backchaining.  If all mts are relevant,
we need to be conservative and only look for universally true backchain control assertions."
  (conservative-constraint-mt mt))

(defun inference-relevant-mt? (assertion-mt &optional inference-mt)
  (and (fort-p assertion-mt)
       (some-pred-value-in-relevant-mts assertion-mt #$highlyRelevantMt
                                        inference-mt 1 :true)))

