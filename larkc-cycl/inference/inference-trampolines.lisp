(defun inference-some-max-floor-mts (mts)
  (setf mts (remove-duplicates mts :test #'hlmt-equal))
  (setf mts (minimize-mts-wrt-core mts))
  (some-max-floor-mts?-cached mts))

;; some-max-floor-mts?-cached is a globally cached function (defun-cached pattern).
;; clear-some-max-floor-mts?-cached is generated by defun-cached.
;; register-mt-dependent-cache-clear-callback is called via the setup phase,
;; but defun-cached :clear-when only supports :hl-store-modified. We handle this
;; manually by registering the mt-dependent callback in a toplevel form.
(defvar *some-max-floor-mts?-cached-caching-state* nil)

(defun clear-some-max-floor-mts?-cached ()
  (let ((cs *some-max-floor-mts?-cached-caching-state*))
    (when cs (caching-state-clear cs)))
  nil)

(defun some-max-floor-mts?-cached (mts)
  (let ((cs *some-max-floor-mts?-cached-caching-state*))
    (when (null cs)
      (setf cs (create-global-caching-state-for-name
                'some-max-floor-mts?-cached
                '*some-max-floor-mts?-cached-caching-state*
                256 'equal 1 0))
      (register-mt-dependent-cache-clear-callback 'clear-some-max-floor-mts?-cached))
    (let ((results (caching-state-lookup cs mts :&memoized-item-not-found&)))
      (when (eq results :&memoized-item-not-found&)
        (setf results (multiple-value-list (some-max-floor-mts? mts)))
        (caching-state-put cs mts results))
      (caching-results results))))

(toplevel
  (note-globally-cached-function 'some-max-floor-mts?-cached))

(defun inference-max-floor-mts-with-cycles-pruned (mts &optional candidates)
  (setf mts (remove-duplicates mts :test #'hlmt-equal))
  (setf mts (minimize-mts-wrt-core mts))
  (if candidates
      (max-floor-mts-with-cycles-pruned mts candidates)
      (inference-max-floor-mts-with-cycles-pruned-cached mts)))

;; inference-max-floor-mts-with-cycles-pruned-cached is a globally cached function.
;; Same manual expansion as some-max-floor-mts?-cached because it uses
;; register-mt-dependent-cache-clear-callback (not :hl-store-modified).
(defvar *inference-max-floor-mts-with-cycles-pruned-cached-caching-state* nil)

(defun clear-inference-max-floor-mts-with-cycles-pruned-cached ()
  (let ((cs *inference-max-floor-mts-with-cycles-pruned-cached-caching-state*))
    (when cs (caching-state-clear cs)))
  nil)

(defun inference-max-floor-mts-with-cycles-pruned-cached (mts)
  (let ((cs *inference-max-floor-mts-with-cycles-pruned-cached-caching-state*))
    (when (null cs)
      (setf cs (create-global-caching-state-for-name
                'inference-max-floor-mts-with-cycles-pruned-cached
                '*inference-max-floor-mts-with-cycles-pruned-cached-caching-state*
                256 'equal 1 0))
      (register-mt-dependent-cache-clear-callback
       'clear-inference-max-floor-mts-with-cycles-pruned-cached))
    (let ((results (caching-state-lookup cs mts :&memoized-item-not-found&)))
      (when (eq results :&memoized-item-not-found&)
        (setf results (multiple-value-list
                       (max-floor-mts-with-cycles-pruned mts)))
        (caching-state-put cs mts results))
      (caching-results results))))

(toplevel
  (note-globally-cached-function 'inference-max-floor-mts-with-cycles-pruned-cached))

