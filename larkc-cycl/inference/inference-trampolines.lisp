;; Reconstructed from Internal Constants:
;; $list39: ((ASSERTION-VAR ASENT SENSE &KEY DONE) &BODY BODY)
;; $sym43$DO_GAF_LOOKUP_INDEX - wraps do-gaf-lookup-index
;; $sym44$INFERENCE_GAF_LOOKUP_INDEX - computes the lookup index
;; $kw45$TRUTH - passed as :truth keyword
;; $sym46$SENSE_TRUTH - converts sense to truth via sense-truth
;; The macro computes a GAF lookup index using inference-gaf-lookup-index,
;; then delegates to do-gaf-lookup-index with the :truth derived from sense.
(defmacro do-inference-gaf-lookup-index ((assertion-var asent sense
                                          &key done) &body body)
  `(do-gaf-lookup-index (,assertion-var (inference-gaf-lookup-index ,asent ,sense)
                          :truth (sense-truth ,sense)
                          :done ,done)
     ,@body))

(defun-memoized inference-gaf-lookup-index (asent sense) (:test equal)
  (best-gaf-lookup-index asent (sense-truth sense)))

(defun-memoized inference-num-gaf-lookup-index (asent sense) (:test equal)
  (num-best-gaf-lookup-index asent (sense-truth sense)))

