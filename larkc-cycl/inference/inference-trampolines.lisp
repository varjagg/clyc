(defun inference-indeterminate-term? (value)
  (cond ((fort-p value)
         (indeterminate-term-p value))
        ((possibly-naut-p value)
         (or (common-non-skolem-indeterminate-term-denoting-function?
              (formula-operator value))
             (memoized-inference-indeterminate-term? value)))
        (t nil)))

;; indeterminate-term-p is a globally cached function (defun-cached pattern).
;; clear-indeterminate-term-p is generated by defun-cached.
;; register-hl-store-cache-clear-callback is called via :clear-when :hl-store-modified.
(defun-cached indeterminate-term-p (fort) (:test eq :clear-when :hl-store-modified)
  (quoted-isa-in-any-mt? fort #$IndeterminateTerm))

