;;; rewrite-link-data defstruct -- 3 slots, conc-name "rw-link-data-"

(defstruct (rewrite-link-data
            (:conc-name "rw-link-data-"))
  hl-module
  bindings
  supports)

;; rewrite-link-data-p is auto-generated by defstruct
;; rw-link-data-hl-module, rw-link-data-bindings, rw-link-data-supports generated by defstruct
;; _csetf-* handled by (setf rw-link-data-*) from defstruct
;; make-rewrite-link-data generated by defstruct

(defconstant *dtp-rewrite-link-data* 'rewrite-link-data)

