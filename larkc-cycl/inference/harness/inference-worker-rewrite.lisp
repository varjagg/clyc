(defun rewrite-link-p (object)
  (and (problem-link-p object)
       (eq :rewrite (problem-link-type object))))

(defun rewrite-tactic-p (tactic)
  (and (tactic-p tactic)
       (eq :rewrite (tactic-type tactic))))

