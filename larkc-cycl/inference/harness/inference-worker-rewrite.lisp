(defun trigger-restriction-link-listeners (link proof)
  (declare (ignore proof))
  (when (restriction-listening-link-p link)
    (let* ((unrestricted-problem (problem-link-supported-problem link))
           (restricted-mapped-problem
            ;; Likely returns the restriction link's sole supporting mapped problem
            (missing-larkc 35684))
           (restricted-problem (mapped-problem-problem restricted-mapped-problem))
           (restricted-asent (single-literal-problem-atomic-sentence restricted-problem)))
      (declare (ignorable unrestricted-problem))
      (dolist (tactic
               ;; Likely returns the rewrite tactics applicable to unrestricted-problem
               (missing-larkc 35682))
        (let* ((hl-module (tactic-hl-module tactic))
               (rewrite-closure-fn
                ;; Likely retrieves the rewrite closure function from the hl-module
                (missing-larkc 36424))
               (rewritten-closure (funcall rewrite-closure-fn restricted-asent)))
          (dolist (asent-and-supports rewritten-closure)
            (destructuring-bind (asent supports) asent-and-supports
              ;; Likely calls maybe-add-restriction-rewrite-problem or similar
              ;; to create a rewrite problem from the rewritten asent and supports
              (missing-larkc 32960)))))))
  nil)

