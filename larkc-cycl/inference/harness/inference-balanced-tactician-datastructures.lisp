(defun balanced-strategy-activate-strategem-wrt-removal (strategy removal-strategem)
  "[Cyc] note that REMOVAL-STRATEGEM is in STRATEGY's R-box"
  (declare (type balanced-strategy-p strategy))
  (declare (type removal-strategem-p removal-strategem))
  (let ((result nil))
    (setf result (strategy-dispatch strategy :activate-removal-strategem removal-strategem))
    (when result
      (let* ((problem (strategem-problem removal-strategem))
             (index (balanced-strategy-problem-total-strategems-active-wrt-removal strategy))
             (count (dictionary-lookup-without-values index problem 0)))
        (setf count (+ count 1))
        (when (= 1 count)
          (balanced-strategy-note-problem-unpending-wrt-removal strategy problem))
        (dictionary-enter index problem count)
        (return-from balanced-strategy-activate-strategem-wrt-removal count))))
  nil)

(defun balanced-strategy-pop-strategem-wrt-removal (strategy)
  (strategy-dispatch strategy :pop-removal-strategem))

(defun balanced-strategy-activate-strategem-wrt-transformation (strategy transformation-strategem)
  "[Cyc] note that TRANSFORMATION-STRATEGEM is in STRATEGY's T-box"
  (declare (type balanced-strategy-p strategy))
  (declare (type transformation-strategem-p transformation-strategem))
  (when (and (transformation-tactic-p transformation-strategem)
             (tactic-executed? transformation-strategem))
    ;; Likely logs or warns about re-activating an already-executed tactic
    (missing-larkc 35695))
  (let ((result nil))
    (setf result (strategy-dispatch strategy :activate-transformation-strategem transformation-strategem))
    (when result
      (let* ((problem (strategem-problem transformation-strategem))
             (index (balanced-strategy-problem-total-strategems-active-wrt-transformation strategy))
             (count (dictionary-lookup-without-values index problem 0)))
        (setf count (+ count 1))
        (when (= 1 count)
          (balanced-strategy-note-problem-unpending-wrt-transformation strategy problem))
        (dictionary-enter index problem count)
        (return-from balanced-strategy-activate-strategem-wrt-transformation count))))
  nil)

(defun balanced-strategy-activate-strategem (strategy strategem motivation)
  (case motivation
    (:removal (balanced-strategy-activate-strategem-wrt-removal strategy strategem))
    (:transformation (balanced-strategy-activate-strategem-wrt-transformation strategy strategem))
    (otherwise (error "new root strategem activation not yet supported"))))

(defun balanced-strategy-pop-strategem-wrt-transformation (strategy)
  (strategy-dispatch strategy :pop-transformation-strategem))

