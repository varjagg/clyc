(defun balanced-strategy-problem-motivated-wrt-new-root? (strategy problem)
  "[Cyc] Return T iff PROBLEM is motivated to be a new root by STRATEGY"
  (declare (type problem-p problem))
  (sublisp-boolean (dictionary-lookup-without-values
                    (balanced-strategy-problems-motivated-wrt-new-root-table strategy)
                    problem)))

