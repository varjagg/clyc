(defconstant *dtp-balanced-strategy-data* 'balanced-strategy-data)

;; (defun balanced-strategy-data-print-function-trampoline (object stream) ...) -- active declareFunction, no body
;; balanced-strategy-data-p is auto-generated by defstruct

(defun make-balanced-strategy-data (&optional arglist)
  (let ((v-new (make-balanced-strategy-data-int)))
    (loop for next = arglist then (cddr next)
          while next
          for current-arg = (first next)
          for current-value = (second next)
          do (case current-arg
               (:problems-motivated-wrt-new-root-table
                (setf (bal-strat-data-problems-motivated-wrt-new-root-table v-new) current-value))
               (:problems-motivated-wrt-removal
                (setf (bal-strat-data-problems-motivated-wrt-removal v-new) current-value))
               (:problems-motivated-wrt-transformation
                (setf (bal-strat-data-problems-motivated-wrt-transformation v-new) current-value))
               (:link-heads-motivated-wrt-removal
                (setf (bal-strat-data-link-heads-motivated-wrt-removal v-new) current-value))
               (:link-heads-motivated-wrt-transformation
                (setf (bal-strat-data-link-heads-motivated-wrt-transformation v-new) current-value))
               (:problems-pending-wrt-new-root
                (setf (bal-strat-data-problems-pending-wrt-new-root v-new) current-value))
               (:problems-pending-wrt-removal
                (setf (bal-strat-data-problems-pending-wrt-removal v-new) current-value))
               (:problems-pending-wrt-transformation
                (setf (bal-strat-data-problems-pending-wrt-transformation v-new) current-value))
               (:new-root-index
                (setf (bal-strat-data-new-root-index v-new) current-value))
               (:new-root-problems
                (setf (bal-strat-data-new-root-problems v-new) current-value))
               (:removal-strategem-index
                (setf (bal-strat-data-removal-strategem-index v-new) current-value))
               (:problem-total-strategems-active-wrt-removal
                (setf (bal-strat-data-problem-total-strategems-active-wrt-removal v-new) current-value))
               (:current-new-root-wrt-removal
                (setf (bal-strat-data-current-new-root-wrt-removal v-new) current-value))
               (:transformation-strategem-index
                (setf (bal-strat-data-transformation-strategem-index v-new) current-value))
               (:problem-total-strategems-active-wrt-transformation
                (setf (bal-strat-data-problem-total-strategems-active-wrt-transformation v-new) current-value))
               (:problem-strategems-set-aside-wrt-removal
                (setf (bal-strat-data-problem-strategems-set-aside-wrt-removal v-new) current-value))
               (:problem-strategems-set-aside-wrt-transformation
                (setf (bal-strat-data-problem-strategems-set-aside-wrt-transformation v-new) current-value))
               (:problem-strategems-thrown-away-wrt-removal
                (setf (bal-strat-data-problem-strategems-thrown-away-wrt-removal v-new) current-value))
               (:problem-strategems-thrown-away-wrt-transformation
                (setf (bal-strat-data-problem-strategems-thrown-away-wrt-transformation v-new) current-value))
               (otherwise
                (error "Invalid slot ~S for construction function" current-arg))))
    v-new))

(defun balanced-strategy-p (object)
  (or (heuristic-balanced-strategy-p object)
      (abductive-strategy-p object)))

(defun new-balanced-strategy-data (removal-index new-root-index transformation-index)
  (let ((data (make-balanced-strategy-data)))
    (setf (bal-strat-data-problems-motivated-wrt-new-root-table data) (new-dictionary #'eq))
    (setf (bal-strat-data-problems-motivated-wrt-removal data) (new-set #'eq))
    (setf (bal-strat-data-problems-motivated-wrt-transformation data) (new-set #'eq))
    (setf (bal-strat-data-link-heads-motivated-wrt-removal data) (new-set #'eq))
    (setf (bal-strat-data-link-heads-motivated-wrt-transformation data) (new-set #'eq))
    (setf (bal-strat-data-problems-pending-wrt-new-root data) (new-set #'eq))
    (setf (bal-strat-data-problems-pending-wrt-removal data) (new-set #'eq))
    (setf (bal-strat-data-problems-pending-wrt-transformation data) (new-set #'eq))
    (setf (bal-strat-data-new-root-index data) new-root-index)
    (setf (bal-strat-data-new-root-problems data) (new-set #'eq))
    (setf (bal-strat-data-removal-strategem-index data) removal-index)
    (setf (bal-strat-data-problem-total-strategems-active-wrt-removal data) (new-dictionary #'eq))
    (setf (bal-strat-data-current-new-root-wrt-removal data) nil)
    (setf (bal-strat-data-transformation-strategem-index data) transformation-index)
    (setf (bal-strat-data-problem-total-strategems-active-wrt-transformation data) (new-dictionary #'eq))
    (setf (bal-strat-data-problem-strategems-set-aside-wrt-removal data) (new-dictionary #'eq))
    (setf (bal-strat-data-problem-strategems-set-aside-wrt-transformation data) (new-dictionary #'eq))
    (setf (bal-strat-data-problem-strategems-thrown-away-wrt-removal data) (new-dictionary #'eq))
    (setf (bal-strat-data-problem-strategems-thrown-away-wrt-transformation data) (new-dictionary #'eq))
    data))

