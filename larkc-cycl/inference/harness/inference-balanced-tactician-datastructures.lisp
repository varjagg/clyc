(defun balanced-strategy-note-strategem-thrown-away-wrt-removal (strategy removal-strategem)
  (declare (type balanced-strategy-p strategy))
  (declare (type removal-strategem-p removal-strategem))
  (let* ((index (balanced-strategy-problem-strategems-thrown-away-wrt-removal strategy))
         (problem (strategem-problem removal-strategem))
         (v-set (dictionary-lookup-without-values index problem nil)))
    (unless (set-p v-set)
      (setf v-set (new-set #'eq))
      (dictionary-enter index problem v-set))
    (set-add removal-strategem v-set)))

