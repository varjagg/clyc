(defun balanced-strategy-problem-motivated-wrt-removal? (strategy problem)
  "[Cyc] Return T iff removal is motivated on PROBLEM in STRATEGY"
  (declare (type problem-p problem))
  (set-member? problem (balanced-strategy-problems-motivated-wrt-removal strategy)))

