(defun balanced-strategy-link-head-motivated-wrt-removal? (strategy link-head)
  "[Cyc] Return T iff removal motivation should propagate through LINK-HEAD in STRATEGY"
  (declare (type motivation-strategem-p link-head))
  (set-member? link-head (balanced-strategy-link-heads-motivated-wrt-removal strategy)))

(defun balanced-strategy-link-head-motivated-wrt-transformation? (strategy link-head)
  "[Cyc] Return T iff transformation motivation should propagate through LINK-HEAD in STRATEGY"
  (declare (type motivation-strategem-p link-head))
  (set-member? link-head (balanced-strategy-link-heads-motivated-wrt-transformation strategy)))

(defun balanced-strategy-link-head-motivated? (strategy motivation link-head)
  (case motivation
    (:removal (balanced-strategy-link-head-motivated-wrt-removal? strategy link-head))
    (:transformation (balanced-strategy-link-head-motivated-wrt-transformation? strategy link-head))
    (otherwise (error "unexpected motivation ~s" motivation))))

(defun balanced-strategy-connected-conjunction-link-motivated-wrt-removal? (strategy connected-conjunction-link)
  (declare (type balanced-strategy-p strategy))
  (declare (type connected-conjunction-link-p connected-conjunction-link))
  (let ((link-head (connected-conjunction-link-tactic connected-conjunction-link)))
    (balanced-strategy-link-head-motivated-wrt-removal? strategy link-head)))

(defun balanced-strategy-problem-pending? (strategy problem motivation)
  "[Cyc] Return T iff PROBLEM is pending in STRATEGY wrt MOTIVATION"
  (declare (type problem-p problem))
  (case motivation
    (:new-root (set-member? problem (balanced-strategy-problems-pending-wrt-new-root strategy)))
    (:removal (set-member? problem (balanced-strategy-problems-pending-wrt-removal strategy)))
    (:transformation (set-member? problem (balanced-strategy-problems-pending-wrt-transformation strategy)))
    (otherwise (error "unexpected motivation ~s" motivation))))

(defun balanced-strategy-problem-totally-pending? (strategy problem)
  (and (balanced-strategy-problem-pending? strategy problem :removal)
       (balanced-strategy-problem-pending? strategy problem :transformation)
       t))

(defun balanced-strategy-problem-active? (strategy problem motivation)
  "[Cyc] @return booleanp; whether PROBLEM is actively being considered for MOTIVATION by STRATEGY."
  (case motivation
    (:new-root (balanced-strategy-problem-active-wrt-new-root? strategy problem))
    (:removal (balanced-strategy-problem-active-wrt-removal? strategy problem))
    (:transformation (balanced-strategy-problem-active-wrt-transformation? strategy problem))
    (otherwise (error "unexpected motivation ~s" motivation))))

(defun balanced-strategy-problem-active-wrt-new-root? (strategy problem)
  "[Cyc] @return booleanp; whether PROBLEM is actively being considered a new root by STRATEGY."
  (declare (type problem-p problem))
  (set-member? problem (balanced-strategy-new-root-problems strategy)))

(defun balanced-strategy-problem-active-wrt-removal? (strategy problem)
  "[Cyc] @return booleanp; whether PROBLEM is actively being considered for removal by STRATEGY."
  (declare (type problem-p problem))
  (let ((index (balanced-strategy-problem-total-strategems-active-wrt-removal strategy)))
    (plusp (dictionary-lookup-without-values index problem 0))))

(defun balanced-strategy-problem-active-wrt-transformation? (strategy problem)
  "[Cyc] @return booleanp; whether PROBLEM is actively being considered for transformation by STRATEGY."
  (declare (type problem-p problem))
  (let ((index (balanced-strategy-problem-total-strategems-active-wrt-transformation strategy)))
    (plusp (dictionary-lookup-without-values index problem 0))))

(defun balanced-strategy-problem-set-aside? (strategy problem motivation)
  (declare (type balanced-strategy-motivation-p motivation))
  (case motivation
    (:new-root nil)
    (:removal (balanced-strategy-problem-set-aside-wrt-removal? strategy problem))
    (:transformation (balanced-strategy-problem-set-aside-wrt-transformation? strategy problem))))

(defun balanced-strategy-problem-set-aside-wrt-removal? (strategy problem)
  "[Cyc] @return booleanp; whether PROBLEM has been set aside for later removal consideration by STRATEGY."
  (declare (type problem-p problem))
  (when (not (balanced-strategy-problem-active-wrt-removal? strategy problem))
    (let* ((index (balanced-strategy-problem-strategems-set-aside-wrt-removal strategy))
           (v-set (dictionary-lookup-without-values index problem nil)))
      (when (and v-set
                 (not (set-empty? v-set)))
        (return-from balanced-strategy-problem-set-aside-wrt-removal? t))))
  nil)

(defun balanced-strategy-problem-set-aside-wrt-transformation? (strategy problem)
  "[Cyc] @return booleanp; whether PROBLEM has been set aside for later transformation consideration by STRATEGY."
  (declare (type problem-p problem))
  (when (not (balanced-strategy-problem-active-wrt-transformation? strategy problem))
    (let* ((index (balanced-strategy-problem-strategems-set-aside-wrt-transformation strategy))
           (v-set (dictionary-lookup-without-values index problem nil)))
      (when (and v-set
                 (not (set-empty? v-set)))
        (return-from balanced-strategy-problem-set-aside-wrt-transformation? t))))
  nil)

(defun balanced-strategy-strategem-set-aside? (strategy strategem motivation)
  (declare (type balanced-strategy-motivation-p motivation))
  (case motivation
    (:removal (balanced-strategy-strategem-set-aside-wrt-removal? strategy strategem))
    (:transformation (balanced-strategy-strategem-set-aside-wrt-transformation? strategy strategem))))

(defun balanced-strategy-strategem-set-aside-wrt-removal? (strategy strategem)
  "[Cyc] @return booleanp; whether STRATEGEM has been set aside for later removal consideration by STRATEGY."
  (declare (type strategem-p strategem))
  (let* ((problem (strategem-problem strategem))
         (index (balanced-strategy-problem-strategems-set-aside-wrt-removal strategy))
         (v-set (dictionary-lookup-without-values index problem nil)))
    (and (set-p v-set)
         (set-member? strategem v-set)
         t)))

