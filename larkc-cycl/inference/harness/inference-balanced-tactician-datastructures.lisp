(defun balanced-strategy-note-problem-motivated-wrt-new-root (strategy problem)
  "[Cyc] note N"
  (declare (type balanced-strategy-p strategy))
  (declare (type problem-p problem))
  (dictionary-enter (balanced-strategy-problems-motivated-wrt-new-root-table strategy) problem :unactivated))

(defun balanced-strategy-note-new-root-activated-wrt-removal (strategy problem)
  (declare (type balanced-strategy-p strategy))
  (declare (type problem-p problem))
  (let ((elapsed (inference-elapsed-internal-real-time-since-start (strategy-inference strategy))))
    (dictionary-enter (balanced-strategy-problems-motivated-wrt-new-root-table strategy) problem elapsed)
    (balanced-strategy-set-current-new-root-wrt-removal strategy problem)
    problem))

(defun balanced-strategy-note-problem-motivated-wrt-removal (strategy problem)
  "[Cyc] note R"
  (declare (type balanced-strategy-p strategy))
  (declare (type problem-p problem))
  (set-add problem (balanced-strategy-problems-motivated-wrt-removal strategy)))

(defun balanced-strategy-note-problem-motivated-wrt-transformation (strategy problem)
  "[Cyc] note T"
  (declare (type balanced-strategy-p strategy))
  (declare (type problem-p problem))
