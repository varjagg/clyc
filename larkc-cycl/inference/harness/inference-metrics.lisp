(defun increment-problem-link-type-historical-counts (link-type)
  (cond
    ((eql link-type :removal)
     (incf *removal-link-historical-count*)
     (incf *content-link-historical-count*))
    ((eql link-type :transformation)
     (incf *transformation-link-historical-count*)
     (incf *content-link-historical-count*))
    ((eql link-type :rewrite)
     (incf *content-link-historical-count*))
    (t
     (incf *structural-link-historical-count*)))
  (incf *problem-link-historical-count*)
  nil)

