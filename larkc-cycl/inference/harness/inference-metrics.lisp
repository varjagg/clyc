;; (defun forward-inference-metrics-time-index () ...) -- active declareFunction, no body
;; (defun forward-inference-metrics-count-index () ...) -- active declareFunction, no body
;; (defun forward-inference-metrics-inference-index () ...) -- active declareFunction, no body
;; (defun finalize-forward-inference-metrics-inference-index () ...) -- active declareFunction, no body
;; (defun forward-inference-metrics-gaf-index () ...) -- active declareFunction, no body
;; (defun clear-forward-inference-metrics () ...) -- active declareFunction, no body

(defun increment-forward-inference-metrics (rule rule-time inference)
  (when *gathering-forward-inference-metrics?*
    (when *browse-forward-inferences?*
      (when inference
        ;; missing-larkc 36297 — likely forward-inference-metrics-inference-index call
        (dictionary-push (missing-larkc 36297) rule inference)))
    (let ((gaf ;; missing-larkc 36387 — likely gets the triggering GAF
            (missing-larkc 36387)))
      (when gaf
        ;; missing-larkc 36293 — likely forward-inference-metrics-gaf-index call
        (dictionary-pushnew (missing-larkc 36293) rule gaf)))
    ;; missing-larkc 36291 — likely forward-inference-metrics-count-index call
    (dictionary-increment (missing-larkc 36291) rule)
    ;; missing-larkc 36300 — likely forward-inference-metrics-time-index call
    (dictionary-increment (missing-larkc 36300) rule rule-time)))

