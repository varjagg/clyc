;; (defun average-problem-store-historical-problem-count () ...) -- active declareFunction, no body

(defglobal *maximum-forward-problem-store-historical-problem-count* 0)

(defvar *expensive-forward-problem-store-threshold* 1000)

(defun update-maximum-forward-problem-store-historical-problem-count (problem-store)
  (let ((count (problem-store-historical-problem-count problem-store)))
    (when *inference-debug?*
      (when (>= count *expensive-forward-problem-store-threshold*)
        (warn "Forward ~S contained ~S problems" problem-store count)))
    (setf *maximum-forward-problem-store-historical-problem-count*
          (max *maximum-forward-problem-store-historical-problem-count* count)))
  *maximum-forward-problem-store-historical-problem-count*)

