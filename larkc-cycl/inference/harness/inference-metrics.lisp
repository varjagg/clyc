(in-package :clyc)

;;; inference-metric struct
;;; print-object is missing-larkc 36325 — CL's default print-object handles this.

(defstruct (inference-metric (:conc-name "INF-METRIC-"))
  name
  evaluation-func
  evaluation-arg1
  cross-product?)

(defconstant *dtp-inference-metric* 'inference-metric)

;;; Functions — following declare_inference_metrics_file() ordering

;; (defun inference-metric-evaluation-arg1-p (object) ...) -- active declareFunction, no body

;; inference-metric-p generated by defstruct
;; inf-metric-name, inf-metric-evaluation-func, inf-metric-evaluation-arg1,
;; inf-metric-cross-product? generated by defstruct
;; _csetf-* generated by defstruct
;; make-inference-metric generated by defstruct

;; (defun print-inference-metric (metric stream depth) ...) -- active declareFunction, no body

(defun new-inference-metric (name evaluation-func evaluation-arg1 cross-product?)
  (declare (type keyword name)
           (type symbol evaluation-func))
  (let ((metric (make-inference-metric)))
    (setf (inf-metric-name metric) name)
    (setf (inf-metric-evaluation-func metric) evaluation-func)
    (setf (inf-metric-evaluation-arg1 metric) evaluation-arg1)
    (setf (inf-metric-cross-product? metric) cross-product?)
    metric))

;; (defun inference-metric-name (metric) ...) -- active declareFunction, no body
;; (defun inference-metric-evaluation-func (metric) ...) -- active declareFunction, no body
;; (defun inference-metric-evaluation-arg1 (metric) ...) -- active declareFunction, no body
;; (defun inference-metric-cross-product? (metric) ...) -- active declareFunction, no body
;; (defun inference-metric-evaluate (metric problem-store inference) ...) -- active declareFunction, no body
;; (defun inference-metric-property-p (object) ...) -- active declareFunction, no body

(defun declare-inference-metric (name evaluation-func evaluation-arg1 &optional cross-product?)
  (let ((metric (new-inference-metric name evaluation-func evaluation-arg1 cross-product?)))
    (setf (gethash name *inference-metrics-store*) metric)
    metric))

