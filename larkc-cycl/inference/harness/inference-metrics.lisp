;;; Forward inference metrics

(defvar *gathering-forward-inference-metrics?* nil
  "[Cyc] Whether we are gathering metrics on the expense of forward inference.")

;; gathering-forward-inference-metrics — active declareMacro
;; TODO: Reconstruct macro body from Internal Constants.
;; $list304 = ((&BODY BODY)), $sym305$CLET, $list306 = ((*GATHERING-FORWARD-INFERENCE-METRICS?* T))
(defmacro gathering-forward-inference-metrics (&body body)
  `(let ((*gathering-forward-inference-metrics?* t))
     ,@body))

