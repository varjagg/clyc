;;; Macros: do-join-link-first-proofs, do-join-link-second-proofs
;; Reconstructed from Internal Constants:
;; $list21 = ((BINDINGS-VAR PROOF-VAR JOIN-LINK) &BODY BODY) -- arglist
;; $sym22/$sym28 = INDEX gensym, $sym23/$sym29 = PROOF-LIST-VAR gensym
;; $sym24 = CLET, $sym25 = JOIN-LINK-FIRST-PROOF-INDEX, $sym26 = DO-DICTIONARY, $sym27 = DO-LIST
;; $sym30 = JOIN-LINK-SECOND-PROOF-INDEX
;; Confirmed by register-macro-helper calls in setup.
(defmacro do-join-link-first-proofs ((bindings-var proof-var join-link) &body body)
  (with-temp-vars (index proof-list-var)
    `(let ((,index (join-link-first-proof-index ,join-link)))
       (do-dictionary (,bindings-var ,proof-list-var ,index)
         (dolist (,proof-var ,proof-list-var)
           ,@body)))))

(defmacro do-join-link-second-proofs ((bindings-var proof-var join-link) &body body)
  (with-temp-vars (index proof-list-var)
    `(let ((,index (join-link-second-proof-index ,join-link)))
       (do-dictionary (,bindings-var ,proof-list-var ,index)
         (dolist (,proof-var ,proof-list-var)
           ,@body)))))

(defun join-link-join-vars (join-link)
  (j-link-data-join-vars (problem-link-data join-link)))

(defun join-link-first-proof-index (join-link)
  (j-link-data-first-proof-index (problem-link-data join-link)))

(defun join-link-second-proof-index (join-link)
  (j-link-data-second-proof-index (problem-link-data join-link)))

(defun join-link-first-mapped-problem (join-link)
  (first (problem-link-supporting-mapped-problems join-link)))

(defun join-link-second-mapped-problem (join-link)
  (second (problem-link-supporting-mapped-problems join-link)))

(defun join-link-first-problem (join-link)
  (mapped-problem-problem (join-link-first-mapped-problem join-link)))

(defun join-link-second-problem (join-link)
  (mapped-problem-problem (join-link-second-mapped-problem join-link)))

(defun join-link-trigger-variable-map (join-link trigger-is-first?)
  (mapped-problem-variable-map (join-link-trigger-mapped-problem join-link trigger-is-first?)))

(defun join-link-trigger-mapped-problem (join-link trigger-is-first?)
  (if trigger-is-first?
      (join-link-first-mapped-problem join-link)
      (join-link-second-mapped-problem join-link)))

(defun join-link-sibling-mapped-problem (join-link trigger-is-first?)
  (if trigger-is-first?
      (join-link-second-mapped-problem join-link)
      (join-link-first-mapped-problem join-link)))

(defun join-link-first-proofs-lookup (join-link proof-bindings)
  (let* ((index (join-link-first-proof-index join-link))
         (canonical-proof-bindings (canonicalize-proof-bindings proof-bindings))
         (first-proofs (gethash canonical-proof-bindings index)))
    first-proofs))

(defun join-link-second-proofs-lookup (join-link proof-bindings)
  (let* ((index (join-link-second-proof-index join-link))
         (canonical-proof-bindings (canonicalize-proof-bindings proof-bindings))
         (second-proofs (gethash canonical-proof-bindings index)))
    second-proofs))

(defun join-link-sibling-proofs-lookup (join-link trigger-proof-bindings-wrt-supported trigger-is-first?)
  (if trigger-is-first?
      (join-link-second-proofs-lookup join-link trigger-proof-bindings-wrt-supported)
      (join-link-first-proofs-lookup join-link trigger-proof-bindings-wrt-supported)))

(defun join-link-shared-proof-bindings (join-link trigger-proof-bindings trigger-is-first?)
  (let* ((shared-supported-vars (join-link-join-vars join-link))
         (trigger-to-supported-variable-map (join-link-trigger-variable-map join-link trigger-is-first?))
         (trigger-proof-bindings-wrt-supported (transfer-variable-map-to-bindings-filtered trigger-to-supported-variable-map trigger-proof-bindings))
         (shared-trigger-proof-bindings-wrt-supported (filter-bindings-by-variables trigger-proof-bindings-wrt-supported shared-supported-vars)))
    shared-trigger-proof-bindings-wrt-supported))

(defun join-link-tactic (join-link)
  (let ((supported-problem (problem-link-supported-problem join-link)))
    (do-problem-tactics (join-tactic supported-problem :hl-module *join-module*)
      (when (eq join-link (join-tactic-link join-tactic))
        (return-from join-link-tactic join-tactic)))
    (unless (tactically-unexamined-problem-p supported-problem)
      (error "couldn't find the join tactic for ~s" join-link))
    nil))

(defun add-join-link-first-proof (join-link v-bindings proof)
  "[Cyc] Indexes PROOF by BINDINGS as a first proof in JOIN-LINK"
  (declare (type join-link-p join-link)
           (type proof-p proof))
  (let* ((index (join-link-first-proof-index join-link))
         (canonical-bindings (canonicalize-proof-bindings v-bindings)))
    (dictionary-push index canonical-bindings proof))
  join-link)

;; (defun remove-join-link-first-proof (join-link v-bindings proof) ...) -- active declareFunction, no body

(defun add-join-link-second-proof (join-link v-bindings proof)
  "[Cyc] Indexes PROOF by BINDINGS as a second proof in JOIN-LINK"
  (declare (type join-link-p join-link)
           (type proof-p proof))
  (let* ((index (join-link-second-proof-index join-link))
         (canonical-bindings (canonicalize-proof-bindings v-bindings)))
    (dictionary-push index canonical-bindings proof))
  join-link)

;; (defun remove-join-link-second-proof (join-link v-bindings proof) ...) -- active declareFunction, no body

(defun add-join-link-proof (join-link trigger-proof trigger-is-first?)
  "[Cyc] TRIGGER-PROOF must be a :proven proof, because otherwise it would not have bubbled up to JOIN-LINK."
  (must (proof-proven? trigger-proof) "~a was a rejected proof" trigger-proof)
  (let ((shared-trigger-proof-bindings (join-link-shared-proof-bindings join-link (proof-bindings trigger-proof) trigger-is-first?)))
    (if trigger-is-first?
        (add-join-link-first-proof join-link shared-trigger-proof-bindings trigger-proof)
        (add-join-link-second-proof join-link shared-trigger-proof-bindings trigger-proof)))
  nil)

