(in-package :clyc)

;;; Struct: join-link-data

(defstruct (join-link-data (:conc-name "J-LINK-DATA-"))
  join-vars
  first-proof-index
  second-proof-index)

(defconstant *dtp-join-link-data* 'join-link-data)

(defmethod print-object ((object join-link-data) stream)
  (default-struct-print-function object stream 0))

;; join-link-data-p is generated by defstruct

(defun new-join-link-data (first-mapped-problem second-mapped-problem)
  (let ((data (make-join-link-data)))
    (setf (j-link-data-join-vars data) (shared-sibling-vars first-mapped-problem second-mapped-problem))
    (setf (j-link-data-first-proof-index data) (new-dictionary #'equal))
    (setf (j-link-data-second-proof-index data) (new-dictionary #'equal))
    data))

;; (defun valid-join-link-data-p (object) ...) -- active declareFunction, no body

(defun join-link-p (object)
  (and (problem-link-p object)
       (eq :join (problem-link-type object))))

(defun maybe-new-join-link (supported-problem first-supporting-mapped-problem second-supporting-mapped-problem)
  "[Cyc] Return join-link-p, either the already existing one or a new one."
  (do-problem-argument-links (candidate-link supported-problem :type :join)
    (when (and (mapped-problem-equal first-supporting-mapped-problem
                                     (join-link-first-mapped-problem candidate-link))
               (mapped-problem-equal second-supporting-mapped-problem
                                     (join-link-second-mapped-problem candidate-link)))
      (return-from maybe-new-join-link candidate-link)))
  (new-join-link supported-problem first-supporting-mapped-problem second-supporting-mapped-problem))

(defun new-join-link (supported-problem first-supporting-mapped-problem second-supporting-mapped-problem)
  (declare (type mapped-problem-p first-supporting-mapped-problem)
           (type mapped-problem-p second-supporting-mapped-problem))
  (let* ((link (new-problem-link :join supported-problem))
         (data (new-join-link-data first-supporting-mapped-problem second-supporting-mapped-problem)))
    (set-problem-link-data link data)
    (connect-supporting-mapped-problem-with-dependent-link second-supporting-mapped-problem link)
    (connect-supporting-mapped-problem-with-dependent-link first-supporting-mapped-problem link)
    (propagate-problem-link link)
    link))

