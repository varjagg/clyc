(defun find-or-create-join-link-supporting-mapped-problems (store dnf-clause first-supporting-problem-spec)
  (let ((first-mapped-problem (find-or-create-problem-from-subclause-spec store dnf-clause first-supporting-problem-spec))
        (second-mapped-problem (find-or-create-problem-without-subclause-spec store dnf-clause first-supporting-problem-spec)))
    (values first-mapped-problem second-mapped-problem)))

(defun first-problem-shared-vars (first-mapped-problem second-mapped-problem)
  "[Cyc] Return listp; the sorted list of variables in FIRST-MAPPED-PROBLEM that also appear (modulo variable maps) in SECOND-MAPPED-PROBLEM."
  (let ((shared-sibling-vars (shared-sibling-vars first-mapped-problem second-mapped-problem)))
    (apply-bindings-backwards (mapped-problem-variable-map first-mapped-problem) shared-sibling-vars)))

(defun second-problem-shared-vars (first-mapped-problem second-mapped-problem)
  "[Cyc] Return listp; the sorted list of variables in SECOND-MAPPED-PROBLEM that also appear (modulo variable maps) in FIRST-MAPPED-PROBLEM."
  (let ((shared-sibling-vars (shared-sibling-vars first-mapped-problem second-mapped-problem)))
    (apply-bindings-backwards (mapped-problem-variable-map second-mapped-problem) shared-sibling-vars)))

(defun shared-sibling-vars (first-mapped-problem second-mapped-problem)
  "[Cyc] Return listp; the sorted list of variables in both FIRST-MAPPED-PROBLEM and SECOND-MAPPED-PROBLEM in the variable space of their common supported problem. Since the values (cdrs) of each variable map are already in the variable space of their common supported problem, we just take the intersection of the values of those two variable maps."
  (let ((shared-vars nil)
        (first-variable-map (mapped-problem-variable-map first-mapped-problem))
        (second-variable-map (mapped-problem-variable-map second-mapped-problem)))
    (dolist (variable-binding first-variable-map)
      (let ((supported-var (variable-binding-value variable-binding)))
        (when (member? supported-var second-variable-map #'eq #'variable-binding-value)
          (push supported-var shared-vars))))
    (sort-hl-variable-list shared-vars)))

(defparameter *join-module* (inference-structural-module :join))

(defun join-tactic-p (object)
  (and (tactic-p object)
       (eq *join-module* (tactic-hl-module object))))

(defun new-join-tactic (join-link first-supporting-problem-spec)
  (let* ((problem (problem-link-supported-problem join-link))
         (data (list join-link first-supporting-problem-spec))
         (tactic (new-tactic problem *join-module* data)))
    (do-problem-relevant-strategies (strategy problem)
      (strategy-note-new-tactic strategy tactic))
    tactic))

(defun join-tactic-link (join-tactic)
  "[Cyc] Return nil or problem-link-p; the link created by JOIN-TACTIC. NIL should only occur if the tactic has been discarded."
  (first (tactic-data join-tactic)))

(defun join-tactic-first-supporting-problem-spec (tactic)
  "[Cyc] Return subclause-spec-p"
  (second (tactic-data tactic)))

(defun join-tactic-first-problem (join-tactic)
  (let ((link (join-tactic-link join-tactic)))
    (when link
      (join-link-first-problem link))))

(defun join-tactic-second-problem (join-tactic)
  (let ((link (join-tactic-link join-tactic)))
    (when link
      (join-link-second-problem link))))

(defun join-tactic-lookahead-problems (join-tactic)
  (let ((first-problem (join-tactic-first-problem join-tactic))
        (second-problem (join-tactic-second-problem join-tactic)))
    (unless (and first-problem second-problem)
      (multiple-value-bind (first-mapped-problem second-mapped-problem)
          (find-or-create-join-tactic-supporting-mapped-problems join-tactic)
        (setf first-problem (mapped-problem-problem first-mapped-problem))
        (setf second-problem (mapped-problem-problem second-mapped-problem))))
    (values first-problem second-problem)))

(defun determine-new-join-tactics (supported-problem dnf-clause)
  (when (binary-clause-p dnf-clause)
    (unless (inference-some-backchain-required-asent-in-clause? dnf-clause)
      (let ((done? nil))
        (let ((index 0))
          (dolist (contextualized-asent (neg-lits dnf-clause))
            (declare (ignore contextualized-asent))
            (unless done?
              (let ((first-supporting-problem-spec (new-single-literal-subclause-spec :neg index)))
                (possibly-determine-new-join-tactic supported-problem first-supporting-problem-spec dnf-clause))
              (setf done? t))
            (incf index)))
        (let ((index 0))
          (dolist (contextualized-asent (pos-lits dnf-clause))
            (declare (ignore contextualized-asent))
            (unless done?
              (let ((first-supporting-problem-spec (new-single-literal-subclause-spec :pos index)))
                (possibly-determine-new-join-tactic supported-problem first-supporting-problem-spec dnf-clause))
              (setf done? t))
            (incf index))))))
  nil)

(defun possibly-determine-new-join-tactic (supported-problem first-supporting-problem-spec dnf-clause)
  "[Cyc] Possibly create a new :JOIN tactic for PROBLEM in which FIRST-SUPPORTING-PROBLEM-SPEC specifies the literals of DNF-CLAUSE which should be the first supporting problem and the remaining literals should be the second supporting problem."
  (declare (type subclause-spec-p first-supporting-problem-spec))
  (let ((store (problem-store supported-problem)))
    (multiple-value-bind (first-mapped-problem second-mapped-problem)
        (find-or-create-join-link-supporting-mapped-problems store dnf-clause first-supporting-problem-spec)
      (let ((join-link (maybe-new-join-link supported-problem first-mapped-problem second-mapped-problem)))
        (new-join-tactic join-link first-supporting-problem-spec)))))

(defun compute-strategic-properties-of-join-tactic (tactic strategy)
  (declare (type join-tactic-p tactic)
           (type strategy-p strategy))
  (let* ((join-link (join-tactic-link tactic))
         (first-mapped-problem (join-link-first-mapped-problem join-link))
         (second-mapped-problem (join-link-second-mapped-problem join-link)))
    (unless (preference-level-p (tactic-preference-level tactic))
      (multiple-value-bind (preference-level justification)
          (compute-join-tactic-preference-level first-mapped-problem second-mapped-problem :tactical)
        (set-tactic-preference-level tactic preference-level justification)))
    (multiple-value-bind (preference-level justification)
        (compute-join-tactic-preference-level first-mapped-problem second-mapped-problem strategy)
      (set-tactic-strategic-preference-level tactic strategy preference-level justification))
    (let ((productivity (compute-join-tactic-productivity first-mapped-problem second-mapped-problem strategy)))
      (set-tactic-strategic-productivity tactic strategy productivity))
    tactic))

(defparameter *join-productivity-scaling-factor* 8
  "[Cyc] A scaling factor by which to reduce the estimated productivities of join tactics. This should really be done by adding an additional cost factor to consider instead of lumping it into productivity.")

(defun compute-join-tactic-productivity (first-mapped-problem second-mapped-problem strategy)
  "[Cyc] The productivity of a :join tactic is the sum of the productivities of its subproblems."
  (declare (type mapped-problem-p first-mapped-problem)
           (type mapped-problem-p second-mapped-problem)
           (type strategy-p strategy))
  (let* ((first-problem (mapped-problem-problem first-mapped-problem))
         (second-problem (mapped-problem-problem second-mapped-problem))
         (first-productivity (memoized-problem-max-removal-productivity first-problem strategy))
         (second-productivity (memoized-problem-max-removal-productivity second-problem strategy))
         (raw-join-productivity (productivity-max first-productivity second-productivity))
         (join-productivity (productivity-divide-number raw-join-productivity *join-productivity-scaling-factor*)))
    join-productivity))

(defun compute-join-tactic-preference-level (first-mapped-problem second-mapped-problem strategic-context)
  "[Cyc] The preference level of a :join tactic is the min of the preference levels of its subproblems."
  (declare (type mapped-problem-p first-mapped-problem)
           (type mapped-problem-p second-mapped-problem)
           (type strategic-context-p strategic-context))
  (let* ((first-problem (mapped-problem-problem first-mapped-problem))
         (first-problem-shared-vars (first-problem-shared-vars first-mapped-problem second-mapped-problem))
         (second-problem (mapped-problem-problem second-mapped-problem))
         (second-problem-shared-vars (second-problem-shared-vars first-mapped-problem second-mapped-problem)))
    (multiple-value-bind (first-preference-level first-justification)
        (memoized-problem-global-preference-level first-problem strategic-context first-problem-shared-vars)
      (multiple-value-bind (second-preference-level second-justification)
          (memoized-problem-global-preference-level second-problem strategic-context second-problem-shared-vars)
        (if (preference-level-< first-preference-level second-preference-level)
            (let ((justification (concatenate 'string "first problem: " first-justification)))
              (values first-preference-level justification))
            (let ((justification (concatenate 'string "second problem: " second-justification)))
              (values second-preference-level justification)))))))

(defun execute-join-tactic (tactic)
  (multiple-value-bind (first-mapped-problem second-mapped-problem)
      (find-or-create-join-tactic-supporting-mapped-problems tactic)
    (let ((join-link (join-tactic-link tactic)))
      (problem-link-open-and-repropagate-supporting-mapped-problem join-link first-mapped-problem)
      (problem-link-open-and-repropagate-supporting-mapped-problem join-link second-mapped-problem)))
  (when (tactic-preferred? tactic :tactical)
    (discard-all-other-possible-structural-conjunctive-tactics tactic))
  (consider-strategic-ramifications-of-tactic-preference-level tactic)
  tactic)

(defun find-or-create-join-tactic-supporting-mapped-problems (tactic)
  (let* ((problem (tactic-problem tactic))
         (query (problem-query problem)))
    (must (singleton? query) "Join tactics like ~a must only apply to singleton problem queries, but ~s was not a singleton" tactic query)
    (let* ((store (problem-store problem))
           (dnf-clause (first query))
           (first-supporting-problem-spec (join-tactic-first-supporting-problem-spec tactic)))
      (find-or-create-join-link-supporting-mapped-problems store dnf-clause first-supporting-problem-spec))))

(defun new-join-proof (join-link subproofs-with-sub-bindings)
  "[Cyc] Return 0 proof-p; return 1 whether the returned proof was newly created."
  (new-conjunctive-proof join-link subproofs-with-sub-bindings))

(defun join-proof-p (object)
  (and (proof-p object)
       (eq :join (proof-type object))))

(defun bubble-up-proof-to-join-link (trigger-subproof variable-map join-link)
  (let ((trigger-is-first? (mapped-proof-is-first? trigger-subproof variable-map join-link)))
    (add-join-link-proof join-link trigger-subproof trigger-is-first?)
    (bubble-up-proof-to-join-link-int trigger-subproof variable-map join-link trigger-is-first?))
  nil)

(defun mapped-proof-is-first? (subproof proof-variable-map join-link)
  (let* ((first-mapped-problem (join-link-first-mapped-problem join-link))
         (first-problem (mapped-problem-problem first-mapped-problem))
         (subproof-supported-problem (proof-supported-problem subproof)))
    (when (eq first-problem subproof-supported-problem)
      (let ((first-variable-map (mapped-problem-variable-map first-mapped-problem)))
        (when (bindings-equal? first-variable-map proof-variable-map)
          (return-from mapped-proof-is-first? t)))))
  nil)

(defun bubble-up-proof-to-join-link-int (trigger-subproof variable-map join-link trigger-is-first?)
  (let* ((proofs nil)
         (trigger-proof-bindings (proof-bindings trigger-subproof))
         (join-bindings (join-link-shared-proof-bindings join-link trigger-proof-bindings trigger-is-first?))
         (sibling-proofs (join-link-sibling-proofs-lookup join-link join-bindings trigger-is-first?)))
    (when sibling-proofs
      (let* ((sibling-mapped-problem (join-link-sibling-mapped-problem join-link trigger-is-first?))
             (sibling-variable-map (mapped-problem-variable-map sibling-mapped-problem))
             (sibling-proofs-with-bindings nil))
        (dolist (sibling-proof sibling-proofs)
          (let ((sibling-sub-proof-bindings (transfer-variable-map-to-bindings sibling-variable-map (proof-bindings sibling-proof))))
            (push (cons sibling-proof sibling-sub-proof-bindings) sibling-proofs-with-bindings)))
        (setf sibling-proofs-with-bindings (nreverse sibling-proofs-with-bindings))
        (let* ((trigger-sub-proof-bindings (transfer-variable-map-to-bindings variable-map trigger-proof-bindings))
               (supporting-mapped-proof-lists-by-supporting-problem
                 (if trigger-is-first?
                     (list (list (cons trigger-subproof trigger-sub-proof-bindings))
                           sibling-proofs-with-bindings)
                     (list sibling-proofs-with-bindings
                           (list (cons trigger-subproof trigger-sub-proof-bindings)))))
               (mapped-subproof-lists (cartesian-product supporting-mapped-proof-lists-by-supporting-problem)))
          (dolist (mapped-subproof-list mapped-subproof-lists)
            (multiple-value-bind (proof new?)
                (new-join-proof join-link mapped-subproof-list)
              (if new?
                  (push proof proofs)
                  (possibly-note-proof-processed trigger-subproof))))))
      (setf proofs (nreverse proofs))
      (dolist (proof proofs)
        (bubble-up-proof proof))))
  nil)

