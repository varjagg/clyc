(in-package :clyc)

;;; Tables and accessors mapping SubL symbols to their Java-backend names.
;;; Many declareFunction entries were stripped by LarKC; those appear as
;;; one-line comment stubs at their source-order positions.
;;;
;;; Data-symbol package note: the Java tables contain symbols from both the
;;; default package and the SUBLISP package.  Clyc has no SUBLISP package,
;;; so those symbols are interned into :clyc alongside their default-package
;;; counterparts.  See c-name-translation.lisp for a detailed discussion;
;;; equivalent collisions may also occur here.

(deflexical *java-backend-reserved-words*
  '("abstract" "assert" "boolean" "break" "byte" "case" "catch" "char" "class"
    "const" "continue" "default" "do" "double" "else" "enum" "extends" "false"
    "final" "finally" "float" "for" "goto" "if" "implements" "import"
    "instanceof" "int" "interface" "long" "native" "new" "null" "package"
    "private" "protected" "public" "return" "short" "static" "strictfp"
    "super" "switch" "synchronized" "this" "throw" "throws" "transient"
    "true" "try" "void" "volatile" "while")
  "[Cyc] The complete list of Java language reserved words that cannot be used as identifiers in programs.
   See http://java.sun.com/docs/books/tutorial/java/nutsandbolts/_keywords.html")

(defun java-backend-reserved-word-p (object)
  "[Cyc] Return T iff OBJECT is a reserved word in Java"
  (when (stringp object)
    (dolist (word *java-backend-reserved-words*)
      (when (string= object word)
        (return-from java-backend-reserved-word-p t))))
  nil)

