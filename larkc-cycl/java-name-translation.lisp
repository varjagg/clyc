;; (defun java-backend-global-name-lookup (symbol) ...) -- active declareFunction, no body

(defun initialize-java-backend-global-tables ()
  (let* ((data (nconc (copy-list *java-backend-defined-global-name-data*)
                      (copy-list *java-backend-undefined-global-name-data*)))
         (class-table (make-hash-table :test 'eq :size (length data)))
         (name-table (make-hash-table :test 'eq :size (length data))))
    (dolist (item data)
      (destructuring-bind (symbol class-name java-backend-name &optional binding-type) item
        (declare (ignore binding-type))
        (setf (gethash symbol class-table) class-name)
        (setf (gethash symbol name-table) java-backend-name)))
    (setf *java-backend-global-class-table* class-table)
    (setf *java-backend-global-name-table* name-table)
    (hash-table-count name-table)))

