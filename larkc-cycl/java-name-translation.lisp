(defun initialize-java-backend-function-tables ()
  (setf *java-backend-function-name-table* (make-hash-table :test 'eq :size 500))
  (setf *java-backend-function-class-table* (make-hash-table :test 'eq :size 500))
  (dolist (class-spec *java-backend-defined-function-class-data*)
    (destructuring-bind (class-name &optional symbols) class-spec
      (dolist (symbol symbols)
        (let ((java-backend-name (java-backend-compute-defined-function-name symbol)))
          (setf (gethash symbol *java-backend-function-name-table*) java-backend-name)
          (setf (gethash symbol *java-backend-function-class-table*) class-name)))))
  (let ((data (nconc (copy-list *java-backend-undefined-function-name-data*)
                     (copy-list *java-backend-undefined-arity-function-name-data*))))
    (dolist (item data)
      (destructuring-bind (symbol class-name java-backend-name &optional arglist) item
        (declare (ignore arglist))
        (setf (gethash symbol *java-backend-function-name-table*) java-backend-name)
        (setf (gethash symbol *java-backend-function-class-table*) class-name))))
  (hash-table-count *java-backend-function-name-table*))

(defun java-backend-compute-defined-function-name (function)
  (let ((exception-name (java-backend-defined-function-name-exception-lookup function)))
    (if exception-name
        exception-name
        (java-backend-computed-function-name function))))

(defun java-backend-computed-function-name-internal (function)
  (let ((secure-method-id (java-backend-secure-method-id function)))
    (if secure-method-id
        ;; Likely concatenated "f" with a computed method ID string from secure-method-id;
        ;; evidence: cconcatenate("f", <missing>) with secure-method-id as a non-nil guard.
        (concatenate 'string "f" (missing-larkc 29621))
        (let ((name-basis (java-backend-symbol-name-basis function)))
          (cond
            ((java-backend-reserved-word-p name-basis)
             (concatenate 'string "sublisp_" (format-nil-a-no-copy name-basis)))
            ((digit-char-p (char name-basis 0))
             (concatenate 'string "f_" (format-nil-a-no-copy name-basis)))
            (t name-basis))))))

(defun-memoized java-backend-computed-function-name (function)
    (:test eq)
  (java-backend-computed-function-name-internal function))

(defun java-backend-secure-method-id (function)
  (when (and (eq *cyc-package* (symbol-package function))
             (not (java-backend-predefined-function-p function)))
    (let ((sys-tran (current-system-translation)))
      (when sys-tran
        ;; Likely looked up a method ID from the system translation for secure dispatch;
        ;; evidence: sys-tran is non-nil and we are computing a secure method identifier.
        (missing-larkc 8750)))))

(defun java-backend-symbol-name-basis (variable)
  (let ((name (symbol-name variable)))
    (java-backend-convert-identifier-name name)))

(defun java-backend-convert-identifier-name (name)
  (c-backed-convert-identifier-name name))

